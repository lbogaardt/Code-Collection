Cell[BoxData[
 RowBox[{"uploadAndGetURL", "=", 
  RowBox[{"Function", "[", 
   RowBox[{
    RowBox[{"{", "filePath", "}"}], ",", 
    RowBox[{
     RowBox[{"linkName", "=", 
      RowBox[{"StringReplace", "[", 

        RowBox[{"FileNameTake", "[", "filePath", "]"}], ",", 
        RowBox[{"\"\< \>\"", "->", "\"\<-\>\""}]}], "]"}]}], ";", 
     RowBox[{"CloudPublish", "[", 
      RowBox[{
       RowBox[{"Import", "[", 
        RowBox[{"filePath", ",", " ", "\"\<nb\>\""}], "]"}], ",", 
       "linkName"}], "]"}], ";", 
     RowBox[{"First", "[", 
      RowBox[{"CloudObject", "[", "linkName", "]"}], "]"}]}]}], 
   "]"}]}]], "Input",

  3.7833172181202126`*^9, 3.783317225967063*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"logNormalDistribution", "=", 
   RowBox[{"Function", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"a", ",", "b"}], "}"}], ",", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"max", "=", 
         RowBox[{
          RowBox[{"E", "^", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"-", "a"}], "+", 
             RowBox[{"b", "^", "2"}], "-", 
             RowBox[{
              RowBox[{
               RowBox[{"(", 
                RowBox[{"a", "+", 
                 RowBox[{"Log", "[", 
                  RowBox[{"E", "^", 
                   RowBox[{"(", 
                    RowBox[{
                    RowBox[{"-", "a"}], "+", 
                    RowBox[{"b", "^", "2"}]}], ")"}]}], "]"}]}], ")"}], "^", 
               "2"}], "/", 
              RowBox[{"(", 
               RowBox[{"2", " ", 
                RowBox[{"b", "^", "2"}]}], ")"}]}]}], ")"}]}], "/", 
          RowBox[{"(", 
           RowBox[{"b", " ", 
            RowBox[{"Sqrt", "[", 
             RowBox[{"2", "Pi"}], "]"}]}], ")"}]}]}], "}"}], ",", 
       RowBox[{"Plot", "[", 
        RowBox[{
         RowBox[{"PDF", "[", 
          RowBox[{
           RowBox[{"LogNormalDistribution", "[", 
            RowBox[{"a", ",", "b"}], "]"}], ",", "x"}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"x", ",", 
           RowBox[{"-", "1"}], ",", "15"}], "}"}], ",", 
         RowBox[{"PlotRange", "\[Rule]", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"-", "1"}], ",", "15"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"-", "0.01"}], ",", 
              RowBox[{"1.1", " ", "max"}]}], "}"}]}], "}"}]}], ",", 
         RowBox[{"AspectRatio", "\[Rule]", "0.5"}], ",", 
         RowBox[{"Frame", "\[Rule]", "True"}], ",", 
         RowBox[{"Axes", "\[Rule]", "False"}]}], "]"}]}], "]"}]}], "]"}]}], 
  ";"}]], "Input"],

Cell[BoxData[
 RowBox[{
  RowBox[{"transformation", "=", 
   RowBox[{"Function", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"a", ",", "b"}], "}"}], ",", 
     RowBox[{"Plot", "[", 
      RowBox[{
       RowBox[{"Log", "[", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"x", "-", "a"}], ")"}], "/", "b"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", 
         RowBox[{"-", "1"}], ",", "15"}], "}"}], ",", 
       RowBox[{"PlotRange", "\[Rule]", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "1"}], ",", "15"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "3"}], ",", "3"}], "}"}]}], "}"}]}], ",", 
       RowBox[{"AspectRatio", "\[Rule]", "1"}], ",", 
       RowBox[{"Frame", "\[Rule]", "True"}], ",", 
       RowBox[{"Axes", "\[Rule]", "False"}]}], "]"}]}], "]"}]}], 
  ";"}]], "Input"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"GetPlotRange", "[", "plot_", "]"}], ":=", 
   RowBox[{"First", "@", 
    RowBox[{"Cases", "[", 
     RowBox[{"plot", ",", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"PlotRange", "\[Rule]", "x_"}], ")"}], "\[RuleDelayed]", 
       "x"}], ",", "\[Infinity]"}], "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Options", "[", "CompositePlot", "]"}], "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"AspectRatio", "\[Rule]", "0.6"}], ",", 
     RowBox[{"ImageSize", "\[Rule]", "500"}], ",", 
     RowBox[{"ImagePadding", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"20", ",", "6"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"15", ",", "7"}], "}"}]}], "}"}]}], ",", 
     RowBox[{"Inset", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"0.7", ",", "0.5"}], "}"}]}]}], "}"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"CompositePlot", "[", 
   RowBox[{"main_", ",", "left_", ",", "top_", ",", 
    RowBox[{"OptionsPattern", "[", "]"}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"mrange", "=", 
       RowBox[{"GetPlotRange", "[", "main", "]"}]}], ",", 
      RowBox[{"trange", "=", 
       RowBox[{"GetPlotRange", "[", "top", "]"}]}], ",", 
      RowBox[{"lrange", "=", 
       RowBox[{"GetPlotRange", "[", "left", "]"}]}], ",", "height", ",", 
      "width", ",", "ipl", ",", "ipr", ",", "ipb", ",", "ipt", ",", "f2x", 
      ",", "f2y", ",", "f1x", ",", "f1y", ",", "h1", ",", "h2", ",", "w1", 
      ",", "w2", ",", "xp", ",", "yp", ",", "mtf", ",", "ltf", ",", "ttf", 
      ",", "g", ",", "x", ",", "y", ",", "ar"}], "}"}], ",", 
    RowBox[{
     RowBox[{"ar", "=", 
      RowBox[{"OptionValue", "[", "AspectRatio", "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"ipl", ",", "ipr"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"ipb", ",", "ipt"}], "}"}]}], "}"}], "=", 
      RowBox[{"OptionValue", "[", "ImagePadding", "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"xp", ",", "yp"}], "}"}], "=", 
      RowBox[{"OptionValue", "[", "Inset", "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"xp", "=", 
      RowBox[{"1", "-", "xp"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Assert", "[", 
      RowBox[{
       RowBox[{"mrange", "[", 
        RowBox[{"[", "1", "]"}], "]"}], "\[Equal]", 
       RowBox[{"trange", "[", 
        RowBox[{"[", "1", "]"}], "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Assert", "[", 
      RowBox[{
       RowBox[{"mrange", "[", 
        RowBox[{"[", "2", "]"}], "]"}], "\[Equal]", 
       RowBox[{"lrange", "[", 
        RowBox[{"[", "2", "]"}], "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"MatchQ", "[", 
        RowBox[{
         RowBox[{"OptionValue", "[", "ImageSize", "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"_", ",", "_"}], "}"}]}], "]"}], ",", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"width", ",", "height"}], "}"}], "=", 
        RowBox[{"OptionValue", "[", "ImageSize", "]"}]}], ",", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"width", ",", "height"}], "}"}], "=", 
        RowBox[{
         RowBox[{"OptionValue", "[", "ImageSize", "]"}], " ", 
         RowBox[{"{", 
          RowBox[{"1", ",", "ar"}], "}"}]}]}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"w2", "=", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "-", "xp"}], ")"}], "-", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"ipl", "+", "ipr"}], ")"}], "/", "width"}]}]}], ";", 
     RowBox[{"h2", "=", 
      RowBox[{
       RowBox[{"(", "yp", ")"}], "-", 
       RowBox[{

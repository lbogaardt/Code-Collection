Cell[BoxData[
 RowBox[{
  RowBox[{"findDistributionParameters", "[", "data_List", "]"}], ":=", 
  RowBox[{"With", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"mean", "=", 
       RowBox[{"Mean", "[", "data", "]"}]}], ",", 
      RowBox[{"variance", "=", 
       RowBox[{"Variance", "[", "data", "]"}]}], ",", 
      RowBox[{"skewness", "=", 
       RowBox[{"Skewness", "[", "data", "]"}]}], ",", 
      RowBox[{"kurtosis", "=", 
       RowBox[{"Kurtosis", "[", "data", "]"}]}]}], "}"}], ",", 
    RowBox[{"findDistributionParameters", "[", 
     RowBox[{"mean", ",", "variance", ",", "skewness", ",", "kurtosis"}], 
     "]"}]}], "]"}]}]], "Input",

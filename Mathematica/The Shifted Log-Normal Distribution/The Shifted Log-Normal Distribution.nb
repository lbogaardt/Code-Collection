Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"mean", "=", "24.5"}], ",", 
     RowBox[{"variance", "=", "5.3"}], ",", 
     RowBox[{"skewness", "=", "1.2"}], ",", 
     RowBox[{"kurtosis", "=", "4.8"}], ",", 
     RowBox[{"n", "=", "100000"}]}], "}"}], ",", 
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"parameters", "=", 
       RowBox[{"findDistributionParameters", "[", 
        RowBox[{"mean", ",", "variance", ",", "skewness", ",", "kurtosis"}], 
        "]"}]}], "}"}], ",", 
     RowBox[{"With", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"data", "=", 
         RowBox[{"logInverseCumulativeDistribution", "[", 
          RowBox[{
           RowBox[{"RandomReal", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"0", ",", "1"}], "}"}], ",", "n"}], "]"}], ",", 
           RowBox[{"parameters", "[", 
            RowBox[{"[", "1", "]"}], "]"}], ",", 
           RowBox[{"parameters", "[", 
            RowBox[{"[", "2", "]"}], "]"}], ",", 
           RowBox[{"parameters", "[", 
            RowBox[{"[", "3", "]"}], "]"}], ",", 
           RowBox[{"parameters", "[", 
            RowBox[{"[", "4", "]"}], "]"}]}], "]"}]}], "}"}], ",", 
       RowBox[{"Grid", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
           "\"\<Input\>\"", ",", "mean", ",", "variance", ",", "skewness", 
            ",", "kurtosis"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"\"\<Generated\>\"", ",", 
            RowBox[{"Mean", "[", "data", "]"}], ",", 
            RowBox[{"Variance", "[", "data", "]"}], ",", 
            RowBox[{"Skewness", "[", "data", "]"}], ",", 
            RowBox[{"Kurtosis", "[", "data", "]"}]}], "}"}], ",", 
          RowBox[{"Join", "[", 
           RowBox[{
            RowBox[{"{", "\"\<Parameters\>\"", "}"}], ",", "parameters"}], 
           "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"\"\<Plots\>\"", ",", 
            RowBox[{"Plot", "[", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{"logDistribution", "[", 
                RowBox[{"x", ",", 
                 RowBox[{"parameters", "[", 
                  RowBox[{"[", "1", "]"}], "]"}], ",", 
                 RowBox[{"parameters", "[", 
                  RowBox[{"[", "2", "]"}], "]"}], ",", 
                 RowBox[{"parameters", "[", 
                  RowBox[{"[", "3", "]"}], "]"}], ",", 
                 RowBox[{"parameters", "[", 
                  RowBox[{"[", "4", "]"}], "]"}]}], "]"}], "}"}], ",", 
              RowBox[{"{", 
               RowBox[{"x", ",", "18", ",", "35"}], "}"}]}], "]"}], ",", 
            RowBox[{"Histogram", "[", "data", "]"}], ",", 
            RowBox[{"SmoothHistogram", "[", "data", "]"}]}], "}"}]}], "}"}], 

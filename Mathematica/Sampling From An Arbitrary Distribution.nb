Cell[BoxData[
 RowBox[{"DynamicModule", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"polynomial", "=", "0"}], ",", 
     RowBox[{"distribution", "=", 
      RowBox[{"NormalDistribution", "[", "]"}]}], ",", 
     RowBox[{"coefficients", "=", 
      RowBox[{"{", "}"}]}], ",", 
     RowBox[{"data", "=", 
      RowBox[{"{", "}"}]}], ",", 
     RowBox[{"parameters", "=", 
      RowBox[{"{", "}"}]}]}], "}"}], ",", 
   RowBox[{"Manipulate", "[", 
    RowBox[{
     RowBox[{"Grid", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"Show", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"Plot", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"Function", "[", 
                 RowBox[{
                  RowBox[{"{", "x", "}"}], ",", 
                  RowBox[{"InterpolatingPolynomial", "[", 
                   RowBox[{
                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{"{", 
                    RowBox[{"0", ",", "0.7"}], "}"}], ",", "p1", ",", "p2", 
                    ",", "p3", ",", 
                    RowBox[{"{", 
                    RowBox[{"1", ",", "0.1"}], "}"}]}], "}"}], ",", "x"}], 
                   "]"}]}], "]"}], "[", "x", "]"}], ",", 
               RowBox[{"{", 
                RowBox[{"x", ",", "0", ",", "1"}], "}"}], ",", 
               RowBox[{"PlotRange", "\[Rule]", 
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"{", 
                   RowBox[{"0", ",", "1"}], "}"}], ",", 
                  RowBox[{"{", 
                   RowBox[{"0", ",", "1"}], "}"}]}], "}"}]}]}], "]"}], "}"}], 
            ",", 
            RowBox[{"ImageSize", "\[Rule]", "500"}]}], "]"}], ",", 
          RowBox[{"Show", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"Histogram", "[", 
              RowBox[{"data", ",", "Automatic", ",", "\"\<Probability\>\""}], 
              "]"}], "}"}], ",", 
            RowBox[{"ImageSize", "\[Rule]", "500"}]}], "]"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"coefficients", ",", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"w1", ",", "w2", ",", "w3", ",", "w4", ",", 
             RowBox[{"1", "-", "w1", "-", "w2", "-", "w3", "-", "w4"}]}], 
            "}"}], "/.", "parameters"}]}], "}"}]}], "}"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"p1", ",", 
         RowBox[{"{", 
          RowBox[{".25", ",", "0.6"}], "}"}]}], "}"}], ",", "Locator"}], 
      "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"p2", ",", 
         RowBox[{"{", 
          RowBox[{"0.5", ",", "0.7"}], "}"}]}], "}"}], ",", "Locator"}], 
      "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"p3", ",", 
         RowBox[{"{", 
          RowBox[{".75", ",", "0.5"}], "}"}]}], "}"}], ",", "Locator"}], 
      "}"}], ",", 
     RowBox[{"Button", "[", 
      RowBox[{"\"\<Generate\>\"", ",", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"polynomial", "=", 
           RowBox[{"InterpolatingPolynomial", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{"0", ",", "0.7"}], "}"}], ",", "p1", ",", "p2", ",", 
               "p3", ",", 
               RowBox[{"{", 
                RowBox[{"1", ",", "0.1"}], "}"}]}], "}"}], ",", "x"}], 
            "]"}]}], ",", 
          RowBox[{"coefficients", "=", 
           RowBox[{"bernsteinCoefficients", "[", "polynomial", "]"}]}], ",", 
          RowBox[{"distribution", "=", 
           RowBox[{"MixtureDistribution", "[", 
            RowBox[{"coefficients", ",", 
             RowBox[{"Table", "[", 
              RowBox[{
               RowBox[{"BetaDistribution", "[", 
                RowBox[{
                 RowBox[{
                  RowBox[{"Length", "[", "coefficients", "]"}], "-", "i"}], 
                 ",", 
                 RowBox[{"i", "+", "1"}]}], "]"}], ",", 
               RowBox[{"{", 
                RowBox[{"i", ",", "0", ",", 
                 RowBox[{
                  RowBox[{"Length", "[", "coefficients", "]"}], "-", "1"}]}], 
                "}"}]}], "]"}]}], "]"}]}], ",", 
          RowBox[{"data", "=", 
           RowBox[{"RandomVariate", "[", 
            RowBox[{"distribution", ",", "20000"}], "]"}]}], ",", 
          RowBox[{"Quiet", "[", 
           RowBox[{"parameters", "=", 
            RowBox[{"FindDistributionParameters", "[", 
             RowBox[{"data", ",", 
              RowBox[{"MixtureDistribution", "[", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{"w1", ",", "w2", ",", "w3", ",", "w4", ",", 
                  RowBox[{"1", "-", "w1", "-", "w2", "-", "w3", "-", "w4"}]}],
                  "}"}], ",", 
                RowBox[{"Evaluate", "[", 
                 RowBox[{"Table", "[", 
                  RowBox[{
                   RowBox[{"BetaDistribution", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"Length", "[", "coefficients", "]"}], "-", "i"}], 
                    ",", 
                    RowBox[{"i", "+", "1"}]}], "]"}], ",", 
                   RowBox[{"{", 
                    RowBox[{"i", ",", "0", ",", 
                    RowBox[{
                    RowBox[{"Length", "[", "coefficients", "]"}], "-", 
                    "1"}]}], "}"}]}], "]"}], "]"}]}], "]"}]}], "]"}]}], 
           "]"}]}], "}"}], ";"}]}], "]"}]}], "]"}]}], "]"}]], "Input",

Cell[BoxData[
 RowBox[{
  RowBox[{"bernsteinCoefficients", "[", "pol_", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"t", ",", "n", ",", "c", ",", "a"}], "}"}], ",", 
    RowBox[{
     RowBox[{"t", "=", 
      RowBox[{
       RowBox[{"Variables", "[", "pol", "]"}], "[", 
       RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"n", "=", 
      RowBox[{"Exponent", "[", 
       RowBox[{"pol", ",", "t"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"c", "=", 
      RowBox[{
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"a", "[", "k", "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"k", ",", "0", ",", "n"}], "}"}]}], "]"}], "/.", 
       RowBox[{
        RowBox[{"SolveAlways", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Sum", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"a", "[", "k", "]"}], " ", 
              RowBox[{"Binomial", "[", 
               RowBox[{"n", ",", "k"}], "]"}], " ", 
              RowBox[{"t", "^", 
               RowBox[{"(", 
                RowBox[{"n", "-", "k"}], ")"}]}], " ", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{"1", "-", "t"}], ")"}], "^", "k"}]}], ",", 
             RowBox[{"{", 
              RowBox[{"k", ",", "0", ",", "n"}], "}"}]}], "]"}], "\[Equal]", 
           "pol"}], ",", "t"}], "]"}], "[", 
        RowBox[{"[", "1", "]"}], "]"}]}]}], ";", 
     RowBox[{"c", "/", 
      RowBox[{"Total", "[", "c", "]"}]}]}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.8623820574059143`*^9, 3.862382058458096*^9}, {
  3.8623859911147785`*^9, 3.8623860054958916`*^9}, {3.8624073715972424`*^9, 
  3.8624073770726633`*^9}},

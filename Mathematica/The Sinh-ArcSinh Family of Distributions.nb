Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"jonesBessels", "=", 
  RowBox[{"Function", "[", 
   RowBox[{
    RowBox[{"{", "q", "}"}], ",", 
    RowBox[{
     RowBox[{
      RowBox[{"Exp", "[", 
       RowBox[{"1", "/", "4"}], "]"}], "/", 
      RowBox[{"Sqrt", "[", 
       RowBox[{"8", "Pi"}], "]"}]}], 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"BesselK", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"q", "+", "1"}], ")"}], "/", "2"}], ",", 
         RowBox[{"1", "/", "4"}]}], "]"}], "+", 
       RowBox[{"BesselK", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"q", "-", "1"}], ")"}], "/", "2"}], ",", 
         RowBox[{"1", "/", "4"}]}], "]"}]}], ")"}]}]}], "]"}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.778304818217221*^9, 3.7783048366878576`*^9}, {
  3.7783048713045588`*^9, 3.778304932472551*^9}},
 CellLabel->"In[13]:=",ExpressionUUID->"fb659d42-97b9-1b43-8a7e-1951d5f12ca9"],

Cell[BoxData[
 RowBox[{"Function", "[", 
  RowBox[{
   RowBox[{"{", "q", "}"}], ",", 
   FractionBox[
    RowBox[{
     RowBox[{"Exp", "[", 
      FractionBox["1", "4"], "]"}], " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"BesselK", "[", 
        RowBox[{
         FractionBox[
          RowBox[{"q", "+", "1"}], "2"], ",", 
         FractionBox["1", "4"]}], "]"}], "+", 
       RowBox[{"BesselK", "[", 
        RowBox[{
         FractionBox[
          RowBox[{"q", "-", "1"}], "2"], ",", 
         FractionBox["1", "4"]}], "]"}]}], ")"}]}], 
    SqrtBox[
     RowBox[{"8", " ", "\[Pi]"}]]]}], "]"}]], "Output",
 CellChangeTimes->{3.948790099971075*^9, 3.948790307533043*^9, 
  3.9487920580329323`*^9, 3.948792167399807*^9},
 CellLabel->"Out[13]=",ExpressionUUID->"41ad7d50-61b6-ca41-b677-83f013ca4536"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"jonesMomentsWithoutLocation", "=", 
  RowBox[{"Function", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"m", ",", "b", ",", "c", ",", "d"}], "}"}], ",", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"b", "/", "2"}], ")"}], "^", "m"}], " ", 
     RowBox[{"Sum", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Binomial", "[", 
         RowBox[{"m", ",", "i"}], "]"}], 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"-", "1"}], ")"}], "^", "i"}], " ", 
        RowBox[{"Exp", "[", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"m", "-", 
            RowBox[{"2", "i"}]}], ")"}], 
          RowBox[{"c", "/", "d"}]}], "]"}], 
        RowBox[{"jonesBessels", "[", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"m", "-", 
            RowBox[{"2", "i"}]}], ")"}], "/", "d"}], "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "0", ",", "m"}], "}"}]}], "]"}]}]}], 
   "]"}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.7783049408498044`*^9, 3.7783049789296484`*^9}, {
  3.7783050690982265`*^9, 3.778305111873701*^9}, {3.7783051473951283`*^9, 
  3.7783052276732435`*^9}, {3.778306824705361*^9, 3.7783068373260846`*^9}, {
  3.778307293359281*^9, 3.778307367024885*^9}, {3.7783123275282807`*^9, 
  3.778312347449609*^9}, {3.7783123934387035`*^9, 3.7783125161958904`*^9}, {
  3.778312628875413*^9, 3.7783127217428083`*^9}, {3.7783127557042255`*^9, 
  3.7783127780435686`*^9}, {3.77831325723184*^9, 3.7783132612878666`*^9}, {
  3.7783133068557587`*^9, 3.7783133194762397`*^9}},
 CellLabel->"In[14]:=",ExpressionUUID->"a2488715-a49d-ea43-a36f-15491dc4982b"],

Cell[BoxData[
 RowBox[{"Function", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"m", ",", "b", ",", "c", ",", "d"}], "}"}], ",", 
   RowBox[{
    SuperscriptBox[
     RowBox[{"(", 
      FractionBox["b", "2"], ")"}], "m"], " ", 
    RowBox[{
     UnderoverscriptBox["\[Sum]", 
      RowBox[{"i", "=", "0"}], "m"], 
     RowBox[{
      RowBox[{"Binomial", "[", 
       RowBox[{"m", ",", "i"}], "]"}], " ", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"-", "1"}], ")"}], "i"], " ", 
      RowBox[{"Exp", "[", 
       FractionBox[
        RowBox[{
         RowBox[{"(", 
          RowBox[{"m", "-", 
           RowBox[{"2", " ", "i"}]}], ")"}], " ", "c"}], "d"], "]"}], " ", 
      RowBox[{"jonesBessels", "[", 
       FractionBox[
        RowBox[{"m", "-", 
         RowBox[{"2", " ", "i"}]}], "d"], "]"}]}]}]}]}], "]"}]], "Output",
 CellChangeTimes->{3.9487900999993*^9, 3.948790307542511*^9, 
  3.948792058066084*^9, 3.94879216741543*^9},
 CellLabel->"Out[14]=",ExpressionUUID->"a2dd162d-dfe4-1840-91c0-6c0e5be46182"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"jonesMomentsAboutLocation", "=", 
  RowBox[{"Function", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"m", ",", "l", ",", "b", ",", "c", ",", "d"}], "}"}], ",", 
    RowBox[{
     RowBox[{"jonesMomentsWithoutLocation", "[", 
      RowBox[{"m", ",", "b", ",", "c", ",", "d"}], "]"}], "+", 
     RowBox[{"Sum", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Binomial", "[", 
         RowBox[{"m", ",", "i"}], "]"}], 
        RowBox[{"jonesMomentsWithoutLocation", "[", 
         RowBox[{"i", ",", "b", ",", "c", ",", "d"}], "]"}], 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"-", "l"}], ")"}], "^", 
         RowBox[{"(", 
          RowBox[{"m", "-", "i"}], ")"}]}]}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "0", ",", 
         RowBox[{"m", "-", "1"}]}], "}"}]}], "]"}]}]}], "]"}]}]], "Input",
 InitializationCell->True,

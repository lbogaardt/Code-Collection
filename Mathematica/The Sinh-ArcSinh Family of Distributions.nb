Cell[BoxData[
 RowBox[{"Function", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"x", ",", "a", ",", "b", ",", "c", ",", "d"}], "}"}], ",", 
   RowBox[{
    FractionBox["1", "2"], "-", 
    RowBox[{
     FractionBox["1", "2"], " ", "b", " ", 
     SqrtBox[
      RowBox[{"1", "+", 
       FractionBox[
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"a", "-", "x"}], ")"}], "2"], 
        SuperscriptBox["b", "2"]]}]], " ", 

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"jonesDistribution", "=", 
  RowBox[{"Function", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"x", ",", "a", ",", "b", ",", "c", ",", "d"}], "}"}], ",", 
    RowBox[{"Evaluate", "[", 
     RowBox[{"Simplify", "[", 
      RowBox[{"d", " ", 
       RowBox[{"Sqrt", "[", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"1", "+", 
           RowBox[{
            RowBox[{"jonesNormalTransformation", "[", 
             RowBox[{"x", ",", "a", ",", "b", ",", "c", ",", "d"}], "]"}], "^",
             "2"}]}], ")"}], "/", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"b", "^", "2"}], "+", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"x", "-", "a"}], ")"}], "^", "2"}]}], ")"}]}], "]"}], 
       RowBox[{"PDF", "[", 
        RowBox[{
         RowBox[{"NormalDistribution", "[", "]"}], ",", 
         RowBox[{"jonesNormalTransformation", "[", 
          RowBox[{"x", ",", "a", ",", "b", ",", "c", ",", "d"}], "]"}]}], 
        "]"}]}], "]"}], "]"}]}], "]"}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.7773696127400084`*^9, 3.777369701211505*^9}, {
  3.7773697366086206`*^9, 3.777369752245425*^9}, {3.7773698731653643`*^9, 
  3.7773698764790506`*^9}, {3.7773700218580265`*^9, 3.7773700338599386`*^9}, {
  3.77737031534984*^9, 3.7773704041197443`*^9}, {3.7773704564935083`*^9, 
  3.777370570186495*^9}, {3.783085874759263*^9, 3.7830858890337205`*^9}},
 CellLabel->"In[7]:=",ExpressionUUID->"9442c8d0-e435-b64a-b09a-d0d91d6154a3"],

Cell[BoxData[
 RowBox[{"Function", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"x", ",", "a", ",", "b", ",", "c", ",", "d"}], "}"}], ",", 
   FractionBox[
    RowBox[{"d", " ", 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{
       RowBox[{"-", 
        FractionBox["1", "2"]}], " ", 
       SuperscriptBox[
        RowBox[{"Sinh", "[", 
         RowBox[{"c", "+", 
          RowBox[{"d", " ", 
           RowBox[{"ArcSinh", "[", 
            FractionBox[
             RowBox[{"a", "-", "x"}], "b"], "]"}]}]}], "]"}], "2"]}]], " ", 
     SqrtBox[
      FractionBox[
       SuperscriptBox[
        RowBox[{"Cosh", "[", 
         RowBox[{"c", "+", 
          RowBox[{"d", " ", 
           RowBox[{"ArcSinh", "[", 
            FractionBox[
             RowBox[{"a", "-", "x"}], "b"], "]"}]}]}], "]"}], "2"], 
       RowBox[{
        SuperscriptBox["a", "2"], "+", 
        SuperscriptBox["b", "2"], "-", 
        RowBox[{"2", " ", "a", " ", "x"}], "+", 
        SuperscriptBox["x", "2"]}]]]}], 
    SqrtBox[
     RowBox[{"2", " ", "\[Pi]"}]]]}], "]"}]], "Output",
 CellChangeTimes->{3.948790099032543*^9, 3.948790306932722*^9, 

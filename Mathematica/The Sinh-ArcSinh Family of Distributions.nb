     SqrtBox[
      FractionBox[
       SuperscriptBox[
        RowBox[{"Cosh", "[", 
         RowBox[{"c", "+", 
          RowBox[{"d", " ", 
           RowBox[{"ArcSinh", "[", 
            FractionBox[
             RowBox[{"a", "-", "x"}], "b"], "]"}]}]}], "]"}], "2"], 
       RowBox[{
        SuperscriptBox["a", "2"], "+", 
        SuperscriptBox["b", "2"], "-", 
        RowBox[{"2", " ", "a", " ", "x"}], "+", 
        SuperscriptBox["x", "2"]}]]]}], 
    SqrtBox[
     RowBox[{"2", " ", "\[Pi]"}]]]}], "]"}]], "Output",

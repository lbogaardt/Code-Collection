 CellLabel->"In[7]:=",ExpressionUUID->"9442c8d0-e435-b64a-b09a-d0d91d6154a3"],

Cell[BoxData[
 RowBox[{"Function", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"x", ",", "a", ",", "b", ",", "c", ",", "d"}], "}"}], ",", 
   FractionBox[
    RowBox[{"d", " ", 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{
       RowBox[{"-", 
        FractionBox["1", "2"]}], " ", 
       SuperscriptBox[
        RowBox[{"Sinh", "[", 
         RowBox[{"c", "+", 
          RowBox[{"d", " ", 
           RowBox[{"ArcSinh", "[", 
            FractionBox[
             RowBox[{"a", "-", "x"}], "b"], "]"}]}]}], "]"}], "2"]}]], " ", 
     SqrtBox[
      FractionBox[
       SuperscriptBox[
        RowBox[{"Cosh", "[", 
         RowBox[{"c", "+", 
          RowBox[{"d", " ", 
           RowBox[{"ArcSinh", "[", 
            FractionBox[
             RowBox[{"a", "-", "x"}], "b"], "]"}]}]}], "]"}], "2"], 
       RowBox[{
        SuperscriptBox["a", "2"], "+", 
        SuperscriptBox["b", "2"], "-", 
        RowBox[{"2", " ", "a", " ", "x"}], "+", 
        SuperscriptBox["x", "2"]}]]]}], 
    SqrtBox[
     RowBox[{"2", " ", "\[Pi]"}]]]}], "]"}]], "Output",
 CellChangeTimes->{3.948790099032543*^9, 3.948790306932722*^9, 

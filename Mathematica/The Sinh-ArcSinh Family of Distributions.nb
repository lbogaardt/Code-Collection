        RowBox[{"Binomial", "[", 
         RowBox[{"m", ",", "i"}], "]"}], 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"-", "1"}], ")"}], "^", "i"}], " ", 
        RowBox[{"Exp", "[", 
         RowBox[{
          RowBox[{"(", 

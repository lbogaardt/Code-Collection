Cell[BoxData[
 RowBox[{"jonesCumulativeDistribution", "=", 
  RowBox[{"Function", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"x", ",", "a", ",", "b", ",", "c", ",", "d"}], "}"}], ",", 
    RowBox[{"Evaluate", "[", 

Cell[BoxData[
 RowBox[{"Function", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"m", ",", "b", ",", "c", ",", "d"}], "}"}], ",", 
   RowBox[{
    SuperscriptBox[

            RowBox[{"Variance", "[", "data", "]"}], ",", 
            RowBox[{"Skewness", "[", "data", "]"}], ",", 
            RowBox[{"Kurtosis", "[", "data", "]"}]}], "}"}], ",", 
          RowBox[{"Join", "[", 
           RowBox[{
            RowBox[{"{", "\"\<Parameters\>\"", "}"}], ",", "parameters"}], 
           "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"\"\<Plots\>\"", ",", 
            RowBox[{"Plot", "[", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{"jonesDistribution", "[", 
                RowBox[{"x", ",", 
                 RowBox[{"parameters", "[", 
                  RowBox[{"[", "1", "]"}], "]"}], ",", 
                 RowBox[{"parameters", "[", 
                  RowBox[{"[", "2", "]"}], "]"}], ",", 
                 RowBox[{"parameters", "[", 
                  RowBox[{"[", "3", "]"}], "]"}], ",", 
                 RowBox[{"parameters", "[", 
                  RowBox[{"[", "4", "]"}], "]"}]}], "]"}], "}"}], ",", 
              RowBox[{"{", 
               RowBox[{"x", ",", "18", ",", "35"}], "}"}]}], "]"}], ",", 
            RowBox[{"Histogram", "[", "data", "]"}], ",", 
            RowBox[{"SmoothHistogram", "[", "data", "]"}]}], "}"}]}], "}"}], 
        "]"}]}], "]"}]}], "]"}]}], "]"}]], "Input",

Cell[CellGroupData[{

Cell["The Sinh-ArcSinh Normal Distribution", "Section",
 CellChangeTimes->{{3.778390651258773*^9, 
  3.778390711381173*^9}},ExpressionUUID->"9801e888-64ad-8b41-9530-\
6bd97911cc7c"],

Cell["\<\
When this transformation is applied to the normal distribution, a new \
distribution is obtained characterised by four parameters which control mean, \
variance, skewness and kurtosis.\
\>", "Text",
 CellChangeTimes->{{3.777372482547079*^9, 
  3.7773726227542515`*^9}},ExpressionUUID->"240a5ad1-aa0e-8b46-8527-\

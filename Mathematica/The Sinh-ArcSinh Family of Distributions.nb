Cell[BoxData[
 RowBox[{"Function", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"x", ",", "a", ",", "b", ",", "c", ",", "d"}], "}"}], ",", 
   RowBox[{
    FractionBox["1", "2"], "-", 
    RowBox[{
     FractionBox["1", "2"], " ", "b", " ", 
     SqrtBox[
      RowBox[{"1", "+", 
       FractionBox[
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"a", "-", "x"}], ")"}], "2"], 
        SuperscriptBox["b", "2"]]}]], " ", 
     SqrtBox[
      FractionBox[
       SuperscriptBox[
        RowBox[{"Cosh", "[", 
         RowBox[{"c", "+", 
          RowBox[{"d", " ", 
           RowBox[{"ArcSinh", "[", 
            FractionBox[
             RowBox[{"a", "-", "x"}], "b"], "]"}]}]}], "]"}], "2"], 
       RowBox[{
        SuperscriptBox["a", "2"], "+", 
        SuperscriptBox["b", "2"], "-", 
        RowBox[{"2", " ", "a", " ", "x"}], "+", 
        SuperscriptBox["x", "2"]}]]], " ", 
     RowBox[{"Erf", "[", 
      FractionBox[
       RowBox[{"Sinh", "[", 
        RowBox[{"c", "+", 
         RowBox[{"d", " ", 
          RowBox[{"ArcSinh", "[", 
           FractionBox[
            RowBox[{"a", "-", "x"}], "b"], "]"}]}]}], "]"}], 
       SqrtBox["2"]], "]"}], " ", 
     RowBox[{"Sech", "[", 
      RowBox[{"c", "+", 
       RowBox[{"d", " ", 
        RowBox[{"ArcSinh", "[", 
         FractionBox[
          RowBox[{"a", "-", "x"}], "b"], "]"}]}]}], "]"}]}]}]}], 

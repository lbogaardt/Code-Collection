                 RowBox[{"parameters", "[", 
                  RowBox[{"[", "2", "]"}], "]"}], ",", 
                 RowBox[{"parameters", "[", 
                  RowBox[{"[", "3", "]"}], "]"}], ",", 
                 RowBox[{"parameters", "[", 
                  RowBox[{"[", "4", "]"}], "]"}]}], "]"}], "}"}], ",", 
              RowBox[{"{", 
               RowBox[{"x", ",", "18", ",", "35"}], "}"}]}], "]"}], ",", 
            RowBox[{"Histogram", "[", "data", "]"}], ",", 
            RowBox[{"SmoothHistogram", "[", "data", "]"}]}], "}"}]}], "}"}], 
        "]"}]}], "]"}]}], "]"}]}], "]"}]], "Input",

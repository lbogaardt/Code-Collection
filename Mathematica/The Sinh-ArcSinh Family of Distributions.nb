  RowBox[{
   RowBox[{"{", "q", "}"}], ",", 
   FractionBox[
    RowBox[{
     RowBox[{"Exp", "[", 
      FractionBox["1", "4"], "]"}], " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"BesselK", "[", 
        RowBox[{
         FractionBox[
          RowBox[{"q", "+", "1"}], "2"], ",", 
         FractionBox["1", "4"]}], "]"}], "+", 
       RowBox[{"BesselK", "[", 
        RowBox[{
         FractionBox[
          RowBox[{"q", "-", "1"}], "2"], ",", 
         FractionBox["1", "4"]}], "]"}]}], ")"}]}], 
    SqrtBox[

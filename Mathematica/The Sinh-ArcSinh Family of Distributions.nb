Cell[BoxData[
 RowBox[{"Function", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"x", ",", "a", ",", "b", ",", "c", ",", "d"}], "}"}], ",", 
   RowBox[{"a", "-", 
    RowBox[{"b", " ", 
     RowBox[{"Sinh", "[", 
      FractionBox[
       RowBox[{
        RowBox[{"-", "c"}], "+", 
        RowBox[{"ArcSinh", "[", 
         RowBox[{
          SqrtBox["2"], " ", 

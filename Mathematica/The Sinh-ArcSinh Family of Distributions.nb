Cell[BoxData[
 RowBox[{"jonesBessels", "=", 
  RowBox[{"Function", "[", 
   RowBox[{
    RowBox[{"{", "q", "}"}], ",", 
    RowBox[{
     RowBox[{
      RowBox[{"Exp", "[", 
       RowBox[{"1", "/", "4"}], "]"}], "/", 
      RowBox[{"Sqrt", "[", 
       RowBox[{"8", "Pi"}], "]"}]}], 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"BesselK", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"q", "+", "1"}], ")"}], "/", "2"}], ",", 
         RowBox[{"1", "/", "4"}]}], "]"}], "+", 
       RowBox[{"BesselK", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"q", "-", "1"}], ")"}], "/", "2"}], ",", 
         RowBox[{"1", "/", "4"}]}], "]"}]}], ")"}]}]}], "]"}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.778304818217221*^9, 3.7783048366878576`*^9}, {
  3.7783048713045588`*^9, 3.778304932472551*^9}},

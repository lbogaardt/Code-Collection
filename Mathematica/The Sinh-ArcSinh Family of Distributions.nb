Cell[BoxData[
 RowBox[{"jonesCumulativeDistribution", "=", 
  RowBox[{"Function", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"x", ",", "a", ",", "b", ",", "c", ",", "d"}], "}"}], ",", 
    RowBox[{"Evaluate", "[", 
     RowBox[{
      RowBox[{"1", "/", "2"}], "+", 
      RowBox[{"Integrate", "[", 
       RowBox[{
        RowBox[{"jonesDistribution", "[", 

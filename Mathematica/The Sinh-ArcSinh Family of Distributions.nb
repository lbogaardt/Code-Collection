Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"jonesMomentsWithoutLocation", "=", 
  RowBox[{"Function", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"m", ",", "b", ",", "c", ",", "d"}], "}"}], ",", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"b", "/", "2"}], ")"}], "^", "m"}], " ", 
     RowBox[{"Sum", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Binomial", "[", 
         RowBox[{"m", ",", "i"}], "]"}], 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"-", "1"}], ")"}], "^", "i"}], " ", 
        RowBox[{"Exp", "[", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"m", "-", 
            RowBox[{"2", "i"}]}], ")"}], 
          RowBox[{"c", "/", "d"}]}], "]"}], 
        RowBox[{"jonesBessels", "[", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"m", "-", 
            RowBox[{"2", "i"}]}], ")"}], "/", "d"}], "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "0", ",", "m"}], "}"}]}], "]"}]}]}], 
   "]"}]}]], "Input",
 InitializationCell->True,

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"jonesDistribution", "=", 
  RowBox[{"Function", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"x", ",", "a", ",", "b", ",", "c", ",", "d"}], "}"}], ",", 
    RowBox[{"Evaluate", "[", 
     RowBox[{"Simplify", "[", 
      RowBox[{"d", " ", 
       RowBox[{"Sqrt", "[", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"1", "+", 
           RowBox[{
            RowBox[{"jonesNormalTransformation", "[", 
             RowBox[{"x", ",", "a", ",", "b", ",", "c", ",", "d"}], "]"}], "^",
             "2"}]}], ")"}], "/", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"b", "^", "2"}], "+", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"x", "-", "a"}], ")"}], "^", "2"}]}], ")"}]}], "]"}], 
       RowBox[{"PDF", "[", 
        RowBox[{
         RowBox[{"NormalDistribution", "[", "]"}], ",", 
         RowBox[{"jonesNormalTransformation", "[", 
          RowBox[{"x", ",", "a", ",", "b", ",", "c", ",", "d"}], "]"}]}], 
        "]"}]}], "]"}], "]"}]}], "]"}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.7773696127400084`*^9, 3.777369701211505*^9}, {

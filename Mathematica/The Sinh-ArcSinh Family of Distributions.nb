       RowBox[{
        SuperscriptBox["a", "2"], "+", 
        SuperscriptBox["b", "2"], "-", 
        RowBox[{"2", " ", "a", " ", "x"}], "+", 
        SuperscriptBox["x", "2"]}]]], " ", 
     RowBox[{"Erf", "[", 
      FractionBox[
       RowBox[{"Sinh", "[", 
        RowBox[{"c", "+", 
         RowBox[{"d", " ", 
          RowBox[{"ArcSinh", "[", 
           FractionBox[
            RowBox[{"a", "-", "x"}], "b"], "]"}]}]}], "]"}], 
       SqrtBox["2"]], "]"}], " ", 
     RowBox[{"Sech", "[", 
      RowBox[{"c", "+", 
       RowBox[{"d", " ", 
        RowBox[{"ArcSinh", "[", 
         FractionBox[
          RowBox[{"a", "-", "x"}], "b"], "]"}]}]}], "]"}]}]}]}], 

Cell[BoxData[
 RowBox[{"Function", "[", 
  RowBox[{
   RowBox[{"{", "q", "}"}], ",", 
   FractionBox[
    RowBox[{
     RowBox[{"Exp", "[", 
      FractionBox["1", "4"], "]"}], " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"BesselK", "[", 
        RowBox[{
         FractionBox[
          RowBox[{"q", "+", "1"}], "2"], ",", 
         FractionBox["1", "4"]}], "]"}], "+", 
       RowBox[{"BesselK", "[", 
        RowBox[{
         FractionBox[
          RowBox[{"q", "-", "1"}], "2"], ",", 
         FractionBox["1", "4"]}], "]"}]}], ")"}]}], 
    SqrtBox[
     RowBox[{"8", " ", "\[Pi]"}]]]}], "]"}]], "Output",
 CellChangeTimes->{3.948790099971075*^9, 3.948790307533043*^9, 

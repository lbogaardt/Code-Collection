Cell[CellGroupData[{

Cell["The Sinh-ArcSinh Transformation", "Section",
 CellChangeTimes->{{3.778390636033173*^9, 
  3.778390708963173*^9}},ExpressionUUID->"da03c53c-932b-0e41-9fc2-\
dd7945011db7"],

Cell["\<\
The Sinh-ArcSinh family of distributions [1], also referred to as the Jones \
distributions, is based on the Sinh-ArcSinh transformation. This \
transformation can adjust the skewnesses and the kurtosis in data.\
\>", "Text",
 CellChangeTimes->{{3.777372482547079*^9, 3.7773726654993477`*^9}, {
   3.778390125192773*^9, 3.778390128187973*^9}, {3.778390364814173*^9, 
   3.7783904945905733`*^9}, {3.7783915347665195`*^9, 
   3.7783916145766315`*^9}, {3.778391727427755*^9, 3.7783917289721646`*^9}, {
   3.778391794390921*^9, 3.7783917953893275`*^9}, 
   3.792911078923213*^9},ExpressionUUID->"3fe4c40a-4687-a648-b37b-\
2e35d326169c"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"jonesTransformation", "=", 
  RowBox[{"Function", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"x", ",", "c", ",", "d"}], "}"}], ",", " ", 
    RowBox[{"Sinh", "[", 
     RowBox[{
      RowBox[{"d", " ", 
       RowBox[{"ArcSinh", "[", "x", "]"}]}], "-", "c"}], "]"}]}], 
   "]"}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.7770010469445715`*^9, 3.777001143478039*^9}, {

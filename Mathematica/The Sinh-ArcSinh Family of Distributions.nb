       RowBox[{"a", "+", 
        RowBox[{"jonesMomentsAboutLocation", "[", 
         RowBox[{"1", ",", "a", ",", "b", ",", "c", ",", "d"}], "]"}]}]}], 
      "}"}], ",", 
     RowBox[{"With", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"variance", "=", 
         RowBox[{"jonesMomentsAboutLocation", "[", 
          RowBox[{"2", ",", "mean", ",", "b", ",", "c", ",", "d"}], "]"}]}], 
        "}"}], ",", 
       FractionBox[
        RowBox[{"jonesMomentsAboutLocation", "[", 
         RowBox[{"m", ",", "mean", ",", "b", ",", "c", ",", "d"}], "]"}], 
        SuperscriptBox["variance", 
         RowBox[{"m", "/", "2"}]]]}], "]"}]}], "]"}]}], "]"}]], "Output",

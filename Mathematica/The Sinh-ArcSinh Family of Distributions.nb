Cell[CellGroupData[{

Cell["Find Distribution Parameters", "Subsection",
 CellChangeTimes->{{3.7783907512703733`*^9, 3.778390752674373*^9}, 
   3.778390792688373*^9, {3.7833163384540806`*^9, 
   3.7833163455365257`*^9}},ExpressionUUID->"6570b4dc-3f9c-634f-aef6-\
b986d5f93e81"],

Cell["Text", "Text",
 CellChangeTimes->{{3.777372482547079*^9, 3.7773726227542515`*^9}, {
  3.7783916826242676`*^9, 
  3.778391683170271*^9}},ExpressionUUID->"fcaa38e3-3cce-ff47-9db3-\
a805c8c7e5a2"],

Cell[BoxData[
 RowBox[{
  RowBox[{"jonesFindDistributionParameters", "[", 
   RowBox[{"mean_", ",", "variance_", ",", "skewness_", ",", "kurtosis_"}], 
   "]"}], ":=", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"a", ",", 
     RowBox[{"Exp", "[", "logb", "]"}], ",", "c", ",", 
     RowBox[{"Exp", "[", "logd", "]"}]}], "}"}], "/.", 
   RowBox[{"FindRoot", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{"mean", ",", "variance", ",", "skewness", ",", "kurtosis"}], 
       "}"}], "==", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"jonesRawMoments", "[", 
         RowBox[{"1", ",", "a", ",", 
          RowBox[{"Exp", "[", "logb", "]"}], ",", "c", ",", 
          RowBox[{"Exp", "[", "logd", "]"}]}], "]"}], ",", 
        RowBox[{"jonesCentralMoments", "[", 
         RowBox[{"2", ",", "a", ",", 
          RowBox[{"Exp", "[", "logb", "]"}], ",", "c", ",", 
          RowBox[{"Exp", "[", "logd", "]"}]}], "]"}], ",", 
        RowBox[{"jonesStandardisedMoments", "[", 
         RowBox[{"3", ",", "a", ",", 
          RowBox[{"Exp", "[", "logb", "]"}], ",", "c", ",", 
          RowBox[{"Exp", "[", "logd", "]"}]}], "]"}], ",", 
        RowBox[{"jonesStandardisedMoments", "[", 
         RowBox[{"4", ",", "a", ",", 
          RowBox[{"Exp", "[", "logb", "]"}], ",", "c", ",", 
          RowBox[{"Exp", "[", "logd", "]"}]}], "]"}]}], "}"}]}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"a", ",", "mean"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"logb", ",", 
         RowBox[{"Log", "[", "variance", "]"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"c", ",", "0.0"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"logd", ",", "0.0"}], "}"}]}], "}"}]}], "]"}]}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.7783018392320795`*^9, 3.778301923098217*^9}, {
  3.778313571239523*^9, 3.778313573954027*^9}, {3.778313704733857*^9, 

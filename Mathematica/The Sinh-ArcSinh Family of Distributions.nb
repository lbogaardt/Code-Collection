Cell[BoxData[
 RowBox[{"jonesMomentsWithoutLocation", "=", 
  RowBox[{"Function", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"m", ",", "b", ",", "c", ",", "d"}], "}"}], ",", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"b", "/", "2"}], ")"}], "^", "m"}], " ", 
     RowBox[{"Sum", "[", 

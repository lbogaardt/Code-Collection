Cell[BoxData[
 RowBox[{"jonesBessels", "=", 
  RowBox[{"Function", "[", 
   RowBox[{
    RowBox[{"{", "q", "}"}], ",", 
    RowBox[{
     RowBox[{
      RowBox[{"Exp", "[", 
       RowBox[{"1", "/", "4"}], "]"}], "/", 
      RowBox[{"Sqrt", "[", 
       RowBox[{"8", "Pi"}], "]"}]}], 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"BesselK", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"q", "+", "1"}], ")"}], "/", "2"}], ",", 
         RowBox[{"1", "/", "4"}]}], "]"}], "+", 
       RowBox[{"BesselK", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"q", "-", "1"}], ")"}], "/", "2"}], ",", 
         RowBox[{"1", "/", "4"}]}], "]"}]}], ")"}]}]}], "]"}]}]], "Input",
 InitializationCell->True,

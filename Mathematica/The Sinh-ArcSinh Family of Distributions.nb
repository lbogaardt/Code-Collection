          RowBox[{
           RowBox[{"RandomReal", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"0", ",", "1"}], "}"}], ",", "n"}], "]"}], ",", 
           RowBox[{"parameters", "[", 

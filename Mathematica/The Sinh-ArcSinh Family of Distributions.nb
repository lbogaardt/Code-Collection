b986d5f93e81"],

Cell["Text", "Text",
 CellChangeTimes->{{3.777372482547079*^9, 3.7773726227542515`*^9}, {
  3.7783916826242676`*^9, 
  3.778391683170271*^9}},ExpressionUUID->"fcaa38e3-3cce-ff47-9db3-\
a805c8c7e5a2"],

Cell[BoxData[
 RowBox[{
  RowBox[{"jonesFindDistributionParameters", "[", 
   RowBox[{"mean_", ",", "variance_", ",", "skewness_", ",", "kurtosis_"}], 
   "]"}], ":=", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"a", ",", 
     RowBox[{"Exp", "[", "logb", "]"}], ",", "c", ",", 
     RowBox[{"Exp", "[", "logd", "]"}]}], "}"}], "/.", 
   RowBox[{"FindRoot", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{"mean", ",", "variance", ",", "skewness", ",", "kurtosis"}], 
       "}"}], "==", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"jonesRawMoments", "[", 
         RowBox[{"1", ",", "a", ",", 
          RowBox[{"Exp", "[", "logb", "]"}], ",", "c", ",", 

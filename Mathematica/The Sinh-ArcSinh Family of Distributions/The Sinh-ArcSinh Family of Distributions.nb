Cell[BoxData[
 RowBox[{"jonesBessels", "=", 
  RowBox[{"Function", "[", 
   RowBox[{
    RowBox[{"{", "q", "}"}], ",", 
    RowBox[{
     RowBox[{
      RowBox[{"Exp", "[", 
       RowBox[{"1", "/", "4"}], "]"}], "/", 
      RowBox[{"Sqrt", "[", 
       RowBox[{"8", "Pi"}], "]"}]}], 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"BesselK", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"q", "+", "1"}], ")"}], "/", "2"}], ",", 
         RowBox[{"1", "/", "4"}]}], "]"}], "+", 
       RowBox[{"BesselK", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"q", "-", "1"}], ")"}], "/", "2"}], ",", 
         RowBox[{"1", "/", "4"}]}], "]"}]}], ")"}]}]}], "]"}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.778304818217221*^9, 3.7783048366878576`*^9}, {
  3.7783048713045588`*^9, 3.778304932472551*^9}}],

Cell[BoxData[
 RowBox[{"jonesMomentsWithoutLocation", "=", 
  RowBox[{"Function", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"m", ",", "b", ",", "c", ",", "d"}], "}"}], ",", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"b", "/", "2"}], ")"}], "^", "m"}], " ", 
     RowBox[{"Sum", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Binomial", "[", 
         RowBox[{"m", ",", "i"}], "]"}], 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"-", "1"}], ")"}], "^", "i"}], " ", 
        RowBox[{"Exp", "[", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"m", "-", 
            RowBox[{"2", "i"}]}], ")"}], 
          RowBox[{"c", "/", "d"}]}], "]"}], 
        RowBox[{"jonesBessels", "[", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"m", "-", 
            RowBox[{"2", "i"}]}], ")"}], "/", "d"}], "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "0", ",", "m"}], "}"}]}], "]"}]}]}], 
   "]"}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.7783049408498044`*^9, 3.7783049789296484`*^9}, {
  3.7783050690982265`*^9, 3.778305111873701*^9}, {3.7783051473951283`*^9, 
  3.7783052276732435`*^9}, {3.778306824705361*^9, 3.7783068373260846`*^9}, {
  3.778307293359281*^9, 3.778307367024885*^9}, {3.7783123275282807`*^9, 
  3.778312347449609*^9}, {3.7783123934387035`*^9, 3.7783125161958904`*^9}, {
  3.778312628875413*^9, 3.7783127217428083`*^9}, {3.7783127557042255`*^9, 
  3.7783127780435686`*^9}, {3.77831325723184*^9, 3.7783132612878666`*^9}, {
  3.7783133068557587`*^9, 3.7783133194762397`*^9}}],

Cell[BoxData[
 RowBox[{"jonesMomentsAboutLocation", "=", 
  RowBox[{"Function", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"m", ",", "l", ",", "b", ",", "c", ",", "d"}], "}"}], ",", 
    RowBox[{
     RowBox[{"jonesMomentsWithoutLocation", "[", 
      RowBox[{"m", ",", "b", ",", "c", ",", "d"}], "]"}], "+", 
     RowBox[{"Sum", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Binomial", "[", 
         RowBox[{"m", ",", "i"}], "]"}], 
        RowBox[{"jonesMomentsWithoutLocation", "[", 
         RowBox[{"i", ",", "b", ",", "c", ",", "d"}], "]"}], 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"-", "l"}], ")"}], "^", 
         RowBox[{"(", 
          RowBox[{"m", "-", "i"}], ")"}]}]}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "0", ",", 
         RowBox[{"m", "-", "1"}]}], "}"}]}], "]"}]}]}], "]"}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.7783186361589804`*^9, 3.7783186653623676`*^9}}],


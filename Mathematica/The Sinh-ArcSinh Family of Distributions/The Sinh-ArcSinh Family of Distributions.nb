   3.777369636849435*^9}, 3.7773728556994247`*^9, {3.783085857863921*^9, 
   3.7830858700635123`*^9}}],

Cell[BoxData[
 RowBox[{"jonesInverseTransformation", "=", 
  RowBox[{"Function", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"x", ",", "c", ",", "d"}], "}"}], ",", 

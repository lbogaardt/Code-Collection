Cell[BoxData[
 RowBox[{
  RowBox[{"jonesFindDistributionParameters", "[", 
   RowBox[{"mean_", ",", "variance_", ",", "skewness_", ",", "kurtosis_"}], 
   "]"}], ":=", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"a", ",", 
     RowBox[{"Exp", "[", "logb", "]"}], ",", "c", ",", 
     RowBox[{"Exp", "[", "logd", "]"}]}], "}"}], "/.", 
   RowBox[{"FindRoot", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{"mean", ",", "variance", ",", "skewness", ",", "kurtosis"}], 
       "}"}], "==", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"jonesRawMoments", "[", 
         RowBox[{"1", ",", "a", ",", 
          RowBox[{"Exp", "[", "logb", "]"}], ",", "c", ",", 
          RowBox[{"Exp", "[", "logd", "]"}]}], "]"}], ",", 
        RowBox[{"jonesCentralMoments", "[", 
         RowBox[{"2", ",", "a", ",", 
          RowBox[{"Exp", "[", "logb", "]"}], ",", "c", ",", 
          RowBox[{"Exp", "[", "logd", "]"}]}], "]"}], ",", 
        RowBox[{"jonesStandardisedMoments", "[", 
         RowBox[{"3", ",", "a", ",", 
          RowBox[{"Exp", "[", "logb", "]"}], ",", "c", ",", 
          RowBox[{"Exp", "[", "logd", "]"}]}], "]"}], ",", 
        RowBox[{"jonesStandardisedMoments", "[", 
         RowBox[{"4", ",", "a", ",", 
          RowBox[{"Exp", "[", "logb", "]"}], ",", "c", ",", 
          RowBox[{"Exp", "[", "logd", "]"}]}], "]"}]}], "}"}]}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"a", ",", "mean"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"logb", ",", 
         RowBox[{"Log", "[", "variance", "]"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"c", ",", "0.0"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"logd", ",", "0.0"}], "}"}]}], "}"}]}], "]"}]}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.7783018392320795`*^9, 3.778301923098217*^9}, {

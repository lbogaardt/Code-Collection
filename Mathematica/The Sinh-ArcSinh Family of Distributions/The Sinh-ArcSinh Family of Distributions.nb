Cell[BoxData[
 RowBox[{"jonesStandardisedMoments", "=", 
  RowBox[{"Function", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"m", ",", "a", ",", "b", ",", "c", ",", "d"}], "}"}], ",", 
    RowBox[{"With", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"mean", "=", 
        RowBox[{"a", "+", 

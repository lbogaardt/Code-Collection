Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"logInverseCumulativeDistribution", "=", 
    RowBox[{"Function", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"x", ",", "a", ",", "b", ",", "c"}], "}"}], ",", 
      RowBox[{"Evaluate", "[", 
       RowBox[{"First", "[", 
        RowBox[{"y", "/.", 
         RowBox[{"Quiet", "[", 
          RowBox[{"Solve", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"logCumulativeDistribution", "[", 
              RowBox[{"y", ",", "a", ",", "b", ",", "c"}], "]"}], "\[Equal]", 
             "x"}], ",", "y"}], "]"}], "]"}]}], "]"}], "]"}]}], "]"}]}], 
   "*)"}], "\[IndentingNewLine]", 
  RowBox[{"logInverseCumulativeDistribution", "=", 
   RowBox[{"Function", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"x", ",", "a", ",", "b", ",", "c"}], "}"}], ",", 
     RowBox[{"c", "+", 
      RowBox[{"E", "^", 
       RowBox[{"(", 
        RowBox[{"a", "-", 
         RowBox[{
          RowBox[{"Sqrt", "[", "2", "]"}], " ", "b", " ", 
          RowBox[{"InverseErf", "[", 
           RowBox[{"1", "-", 
            RowBox[{"2", " ", "x"}]}], "]"}]}]}], ")"}]}]}]}], 
    "]"}]}]}]], "Input",

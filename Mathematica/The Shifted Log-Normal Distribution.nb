      "w2", ",", "xp", ",", "yp", ",", "mtf", ",", "ltf", ",", "ttf", ",", 
      "g", ",", "x", ",", "y", ",", "ar"}], "}"}], ",", 
    RowBox[{
     RowBox[{"ar", "=", 
      RowBox[{"OptionValue", "[", "AspectRatio", "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"ipl", ",", "ipr"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"ipb", ",", "ipt"}], "}"}]}], "}"}], "=", 
      RowBox[{"OptionValue", "[", "ImagePadding", "]"}]}], ";", 
     "\[IndentingNewLine]", 

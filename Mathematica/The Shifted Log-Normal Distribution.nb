Cell["Text [2]", "Text",
 CellChangeTimes->{{3.777372482547079*^9, 3.7773726227542515`*^9}, {
  3.7783916826242676`*^9, 3.778391683170271*^9}, {3.948782743410452*^9, 
  3.9487827440827465`*^9}},ExpressionUUID->"468105c8-fa3a-824e-9251-\
bc1463760986"],

Cell[BoxData[
 RowBox[{
  RowBox[{"findDistributionParameters", "[", 
   RowBox[{"mean_", ",", "variance_", ",", "skewness_", ",", "kurtosis_"}], 
   "]"}], ":=", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"a", ",", 
     RowBox[{"Exp", "[", "logb", "]"}], ",", "c", ",", 
     RowBox[{"Exp", "[", "logd", "]"}]}], "}"}], "/.", 
   RowBox[{"FindRoot", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{"mean", ",", "variance", ",", "skewness", ",", "kurtosis"}], 
       "}"}], "==", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"logRawMoments", "[", 
         RowBox[{"1", ",", "a", ",", 
          RowBox[{"Exp", "[", "logb", "]"}], ",", "c", ",", 
          RowBox[{"Exp", "[", "logd", "]"}]}], "]"}], ",", 
        RowBox[{"logCentralMoments", "[", 
         RowBox[{"2", ",", "a", ",", 
          RowBox[{"Exp", "[", "logb", "]"}], ",", "c", ",", 
          RowBox[{"Exp", "[", "logd", "]"}]}], "]"}], ",", 
        RowBox[{"logStandardisedMoments", "[", 
         RowBox[{"3", ",", "a", ",", 
          RowBox[{"Exp", "[", "logb", "]"}], ",", "c", ",", 
          RowBox[{"Exp", "[", "logd", "]"}]}], "]"}], ",", 
        RowBox[{"logStandardisedMoments", "[", 
         RowBox[{"4", ",", "a", ",", 
          RowBox[{"Exp", "[", "logb", "]"}], ",", "c", ",", 
          RowBox[{"Exp", "[", "logd", "]"}]}], "]"}]}], "}"}]}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"a", ",", "mean"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"logb", ",", 
         RowBox[{"Log", "[", "variance", "]"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"c", ",", "0.0"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"logd", ",", "0.0"}], "}"}]}], "}"}]}], "]"}]}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.7783018392320795`*^9, 3.778301923098217*^9}, {
  3.778313571239523*^9, 3.778313573954027*^9}, {3.778313704733857*^9, 

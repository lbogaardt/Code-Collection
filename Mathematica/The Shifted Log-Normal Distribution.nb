Cell[BoxData[
 RowBox[{
  RowBox[{"logNormalDistribution", "=", 
   RowBox[{"Function", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"a", ",", "b"}], "}"}], ",", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"max", "=", 
         RowBox[{
          RowBox[{"E", "^", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"-", "a"}], "+", 
             RowBox[{"b", "^", "2"}], "-", 
             RowBox[{
              RowBox[{
               RowBox[{"(", 
                RowBox[{"a", "+", 
                 RowBox[{"Log", "[", 
                  RowBox[{"E", "^", 
                   RowBox[{"(", 
                    RowBox[{
                    RowBox[{"-", "a"}], "+", 
                    RowBox[{"b", "^", "2"}]}], ")"}]}], "]"}]}], ")"}], "^", 
               "2"}], "/", 
              RowBox[{"(", 
               RowBox[{"2", " ", 
                RowBox[{"b", "^", "2"}]}], ")"}]}]}], ")"}]}], "/", 
          RowBox[{"(", 
           RowBox[{"b", " ", 
            RowBox[{"Sqrt", "[", 
             RowBox[{"2", "Pi"}], "]"}]}], ")"}]}]}], "}"}], ",", 
       RowBox[{"Plot", "[", 
        RowBox[{
         RowBox[{"PDF", "[", 
          RowBox[{
           RowBox[{"LogNormalDistribution", "[", 
            RowBox[{"a", ",", "b"}], "]"}], ",", "x"}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"x", ",", 
           RowBox[{"-", "1"}], ",", "15"}], "}"}], ",", 
         RowBox[{"PlotRange", "\[Rule]", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"-", "1"}], ",", "15"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"-", "0.01"}], ",", 
              RowBox[{"1.1", " ", "max"}]}], "}"}]}], "}"}]}], ",", 
         RowBox[{"AspectRatio", "\[Rule]", "0.5"}], ",", 
         RowBox[{"Frame", "\[Rule]", "True"}], ",", 
         RowBox[{"Axes", "\[Rule]", "False"}]}], "]"}]}], "]"}]}], "]"}]}], 
  ";"}]], "Input",
 CellLabel->"In[9]:=",ExpressionUUID->"a7064edc-95af-1c4c-b4d1-18e8265ee3bd"],


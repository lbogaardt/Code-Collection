Cell["Visualisation", "Section",
 CellChangeTimes->{{3.7783957100480323`*^9, 3.7783957147748623`*^9}, {
  3.948781945099428*^9, 
  3.948781947599415*^9}},ExpressionUUID->"444e9146-0ae4-664c-a536-\
bcfbf339428b"],

Cell[BoxData[
 RowBox[{"Manipulate", "[", 
  RowBox[{
   RowBox[{"Grid", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"\"\<Cohort effect: rate = f(birthyear)\>\"", 
        ",", "\"\<Age effect: rate = f(age)\>\""}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Show", "[", 
         RowBox[{
          RowBox[{"Plot3D", "[", 
           RowBox[{
            RowBox[{"0.5", "+", 
             RowBox[{"0.1", "*", 
              RowBox[{"Sin", "[", 
               RowBox[{"birthyear", "*", 
                RowBox[{"Pi", "/", "40"}]}], "]"}]}]}], ",", 
            RowBox[{"{", 
             RowBox[{"birthyear", ",", "1900", ",", "2030"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"age", ",", "0", ",", "100"}], "}"}], ",", 
            RowBox[{"PlotRange", "\[Rule]", 
             RowBox[{"{", 
              RowBox[{"0", ",", "1"}], "}"}]}], ",", 
            RowBox[{"AxesLabel", "\[Rule]", 
             RowBox[{"{", 
              
              RowBox[{"\"\<Birthyear\>\"", ",", "\"\<Age\>\"", 
               ",", "\"\<Stop Rate\>\""}], "}"}]}]}], "]"}], ",", 
          RowBox[{"ParametricPlot3D", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"birthyear", ",", 
              RowBox[{"observationyear", "-", "birthyear"}], ",", 
              RowBox[{"0.5", "+", 
               RowBox[{"0.1", "*", 
                RowBox[{"Sin", "[", 
                 RowBox[{"birthyear", "*", 
                  RowBox[{"Pi", "/", "40"}]}], "]"}]}]}]}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"birthyear", ",", "1900", ",", "2030"}], "}"}], ",", 
            RowBox[{"PlotStyle", "\[Rule]", 
             RowBox[{"Thickness", "[", "0.02", "]"}]}]}], "]"}], ",", 
          RowBox[{"Graphics3D", "[", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"Opacity", "[", ".5", "]"}], ",", "Green", ",", 
             RowBox[{"Polygon", "[", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{"observationyear", ",", "0", ",", "0"}], "}"}], ",", 
                RowBox[{"{", 
                 RowBox[{"observationyear", ",", "0", ",", "1"}], "}"}], ",", 
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"observationyear", "-", "100"}], ",", "100", ",", 
                  "1"}], "}"}], ",", 
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"observationyear", "-", "100"}], ",", "100", ",", 
                  "0"}], "}"}]}], "}"}], "]"}]}], "}"}], "]"}], ",", 
          RowBox[{"ImageSize", "\[Rule]", "500"}]}], "]"}], ",", 
        RowBox[{"Show", "[", 
         RowBox[{
          RowBox[{"Plot3D", "[", 
           RowBox[{
            RowBox[{"0.5", "+", 
             RowBox[{"0.1", "*", 
              RowBox[{"Sin", "[", 
               RowBox[{"Pi", "+", 
                RowBox[{"age", "*", 
                 RowBox[{"Pi", "/", "40"}]}]}], "]"}]}]}], ",", 
            RowBox[{"{", 
             RowBox[{"birthyear", ",", "1900", ",", "2030"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"age", ",", "0", ",", "100"}], "}"}], ",", 
            RowBox[{"PlotRange", "\[Rule]", 
             RowBox[{"{", 
              RowBox[{"0", ",", "1"}], "}"}]}], ",", 
            RowBox[{"AxesLabel", "\[Rule]", 
             RowBox[{"{", 
              
              RowBox[{"\"\<Birthyear\>\"", ",", "\"\<Age\>\"", 
               ",", "\"\<Stop Rate\>\""}], "}"}]}]}], "]"}], ",", 
          RowBox[{"ParametricPlot3D", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"birthyear", ",", 
              RowBox[{"observationyear", "-", "birthyear"}], ",", 
              RowBox[{"0.5", "+", 
               RowBox[{"0.1", "*", 
                RowBox[{"Sin", "[", 
                 RowBox[{"Pi", "+", 
                  RowBox[{
                   RowBox[{"(", 
                    RowBox[{"observationyear", "-", "birthyear"}], ")"}], "*", 
                   RowBox[{"Pi", "/", "40"}]}]}], "]"}]}]}]}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"birthyear", ",", "1900", ",", "2030"}], "}"}], ",", 
            RowBox[{"PlotStyle", "\[Rule]", 
             RowBox[{"Thickness", "[", "0.02", "]"}]}]}], "]"}], ",", 
          RowBox[{"Graphics3D", "[", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"Opacity", "[", ".5", "]"}], ",", "Green", ",", 
             RowBox[{"Polygon", "[", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{"observationyear", ",", "0", ",", "0"}], "}"}], ",", 
                RowBox[{"{", 
                 RowBox[{"observationyear", ",", "0", ",", "1"}], "}"}], ",", 
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"observationyear", "-", "100"}], ",", "100", ",", 
                  "1"}], "}"}], ",", 
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"observationyear", "-", "100"}], ",", "100", ",", 
                  "0"}], "}"}]}], "}"}], "]"}]}], "}"}], "]"}], ",", 
          RowBox[{"ImageSize", "\[Rule]", "500"}]}], "]"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Show", "[", 
         RowBox[{
          RowBox[{"Plot", "[", 
           RowBox[{
            RowBox[{"0.5", "+", 
             RowBox[{"0.1", "*", 
              RowBox[{"Sin", "[", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"observationyear", "-", "age"}], ")"}], "*", 
                RowBox[{"Pi", "/", "40"}]}], "]"}]}]}], ",", 
            RowBox[{"{", 
             RowBox[{"age", ",", "0", ",", "100"}], "}"}], ",", 
            RowBox[{"PlotRange", "\[Rule]", 
             RowBox[{"{", 
              RowBox[{"0", ",", "1"}], "}"}]}], ",", 
            RowBox[{"AxesLabel", "\[Rule]", 
             RowBox[{"{", 
              RowBox[{"\"\<Age\>\"", ",", "\"\<Stop Rate\>\""}], "}"}]}]}], 
           "]"}], ",", 
          RowBox[{"ImageSize", "\[Rule]", "500"}]}], "]"}], ",", 
        RowBox[{"Show", "[", 
         RowBox[{
          RowBox[{"Plot", "[", 
           RowBox[{
            RowBox[{"0.5", "+", 
             RowBox[{"0.1", "*", 
              RowBox[{"Sin", "[", 
               RowBox[{"Pi", "+", 
                RowBox[{"age", "*", 
                 RowBox[{"Pi", "/", "40"}]}]}], "]"}]}]}], ",", 
            RowBox[{"{", 
             RowBox[{"age", ",", "0", ",", "100"}], "}"}], ",", 
            RowBox[{"PlotRange", "\[Rule]", 
             RowBox[{"{", 
              RowBox[{"0", ",", "1"}], "}"}]}], ",", 
            RowBox[{"AxesLabel", "\[Rule]", 
             RowBox[{"{", 
              RowBox[{"\"\<Age\>\"", ",", "\"\<Stop Rate\>\""}], "}"}]}]}], 
           "]"}], ",", 
          RowBox[{"ImageSize", "\[Rule]", "500"}]}], "]"}]}], "}"}]}], "}"}], 
    "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"observationyear", ",", "2000", ",", "2030", ",", "2"}], "}"}]}], 
  "]"}]], "Input",
 CellChangeTimes->{{3.863671476887329*^9, 3.8636715540076838`*^9}, {

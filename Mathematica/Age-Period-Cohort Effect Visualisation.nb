Cell[BoxData[
 TagBox[
  StyleBox[
   DynamicModuleBox[{$CellContext`observationyear$$ = 2000, Typeset`show$$ = 
    True, Typeset`bookmarkList$$ = {}, Typeset`bookmarkMode$$ = "Menu", 
    Typeset`animator$$, Typeset`animvar$$ = 1, Typeset`name$$ = 
    "\"untitled\"", Typeset`specs$$ = {{
      Hold[$CellContext`observationyear$$], 2000, 2030, 2, ControlType -> 
      Manipulator}}, Typeset`size$$ = {
    1005.1999999999999`, {387.6409750571117, 393.37290886110776`}}, 
    Typeset`update$$ = 0, Typeset`initDone$$, Typeset`skipInitDone$$ = True, 
    Typeset`keyframeActionsQ$$ = False, Typeset`keyframeList$$ = {}}, 
    DynamicBox[Manipulate`ManipulateBoxes[
     1, StandardForm, "Variables" :> {$CellContext`observationyear$$ = 2000}, 
      "ControllerVariables" :> {}, 
      "OtherVariables" :> {
       Typeset`show$$, Typeset`bookmarkList$$, Typeset`bookmarkMode$$, 
        Typeset`animator$$, Typeset`animvar$$, Typeset`name$$, 
        Typeset`specs$$, Typeset`size$$, Typeset`update$$, Typeset`initDone$$,
         Typeset`skipInitDone$$, Typeset`keyframeActionsQ$$, 
        Typeset`keyframeList$$}, "Body" :> 
      Grid[{{"Cohort effect: rate = f(birthyear)", 
          "Age effect: rate = f(age)"}, {
          Show[
           Plot3D[
           0.5 + 0.1 
             Sin[$CellContext`birthyear (Pi/40)], {$CellContext`birthyear, 
             1900, 2030}, {$CellContext`age, 0, 100}, PlotRange -> {0, 1}, 
            AxesLabel -> {"Birthyear", "Age", "Stop Rate"}], 
           
           ParametricPlot3D[{$CellContext`birthyear, \
$CellContext`observationyear$$ - $CellContext`birthyear, 0.5 + 
             0.1 Sin[$CellContext`birthyear (Pi/
                 40)]}, {$CellContext`birthyear, 1900, 2030}, PlotStyle -> 
            Thickness[0.02]], 
           Graphics3D[{
             Opacity[0.5], Green, 
             
             Polygon[{{$CellContext`observationyear$$, 0, 
                0}, {$CellContext`observationyear$$, 0, 
                1}, {$CellContext`observationyear$$ - 100, 100, 
                1}, {$CellContext`observationyear$$ - 100, 100, 0}}]}], 
           ImageSize -> 500], 
          Show[
           Plot3D[
           0.5 + 0.1 
             Sin[Pi + $CellContext`age (Pi/40)], {$CellContext`birthyear, 
             1900, 2030}, {$CellContext`age, 0, 100}, PlotRange -> {0, 1}, 
            AxesLabel -> {"Birthyear", "Age", "Stop Rate"}], 
           
           ParametricPlot3D[{$CellContext`birthyear, \
$CellContext`observationyear$$ - $CellContext`birthyear, 0.5 + 
             0.1 Sin[Pi + ($CellContext`observationyear$$ - \
$CellContext`birthyear) (Pi/40)]}, {$CellContext`birthyear, 1900, 2030}, 
            PlotStyle -> Thickness[0.02]], 
           Graphics3D[{
             Opacity[0.5], Green, 
             
             Polygon[{{$CellContext`observationyear$$, 0, 
                0}, {$CellContext`observationyear$$, 0, 
                1}, {$CellContext`observationyear$$ - 100, 100, 
                1}, {$CellContext`observationyear$$ - 100, 100, 0}}]}], 
           ImageSize -> 500]}, {
          Show[
           Plot[
           0.5 + 0.1 
             Sin[($CellContext`observationyear$$ - $CellContext`age) (Pi/
                40)], {$CellContext`age, 0, 100}, PlotRange -> {0, 1}, 
            AxesLabel -> {"Age", "Stop Rate"}], ImageSize -> 500], 
          Show[
           Plot[
           0.5 + 0.1 Sin[Pi + $CellContext`age (Pi/40)], {$CellContext`age, 0,
              100}, PlotRange -> {0, 1}, AxesLabel -> {"Age", "Stop Rate"}], 
           ImageSize -> 500]}}], 

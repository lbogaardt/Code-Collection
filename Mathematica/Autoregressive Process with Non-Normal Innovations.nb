Cell[BoxData[{
 RowBox[{"processMeanFromInnovations", "=", 
  RowBox[{"Function", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"equilibrium", ",", "errorMean", ",", "beta"}], "}"}], ",", 
    RowBox[{"equilibrium", "+", 
     RowBox[{"errorMean", "/", 
      RowBox[{"(", 
       RowBox[{"1", "-", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"1", "-", "beta"}], ")"}], "^", "1"}]}], ")"}]}]}]}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"processVarianceFromInnovations", "=", 
  RowBox[{"Function", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"errorVariance", ",", "beta"}], "}"}], ",", 
    RowBox[{"errorVariance", "/", 
     RowBox[{"(", 
      RowBox[{"1", "-", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", "-", "beta"}], ")"}], "^", "2"}]}], ")"}]}]}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"processSkewnessFromInnovations", "=", 
  RowBox[{"Function", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"errorSkewness", ",", "beta"}], "}"}], ",", 
    RowBox[{"errorSkewness", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "-", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"1", "-", "beta"}], ")"}], "^", "2"}]}], ")"}], "^", 
       RowBox[{"(", 
        RowBox[{"3", "/", "2"}], ")"}]}], "/", 
      RowBox[{"(", 
       RowBox[{"1", "-", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"1", "-", "beta"}], ")"}], "^", "3"}]}], ")"}]}]}]}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"processKurtosisFromInnovations", "=", 
  RowBox[{"Function", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"errorKurtosis", ",", "beta"}], "}"}], ",", 
    RowBox[{"3", "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"errorKurtosis", "-", "3"}], ")"}], 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", "-", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"1", "-", "beta"}], ")"}], "^", "2"}]}], ")"}], "^", 
        RowBox[{"(", 
         RowBox[{"4", "/", "2"}], ")"}]}], "/", 
       RowBox[{"(", 
        RowBox[{"1", "-", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"1", "-", "beta"}], ")"}], "^", "4"}]}], ")"}]}]}]}]}], 
   "]"}]}]}], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.778319414585282*^9, 3.7783195278118076`*^9}, {

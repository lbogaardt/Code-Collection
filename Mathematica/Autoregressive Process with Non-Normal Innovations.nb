   RowBox[{
    RowBox[{"{", 
     RowBox[{"errorKurtosis", ",", "beta"}], "}"}], ",", 
    RowBox[{"3", "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"errorKurtosis", "-", "3"}], ")"}], 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", "-", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"1", "-", "beta"}], ")"}], "^", "2"}]}], ")"}], "^", 
        RowBox[{"(", 
         RowBox[{"4", "/", "2"}], ")"}]}], "/", 
       RowBox[{"(", 
        RowBox[{"1", "-", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"1", "-", "beta"}], ")"}], "^", "4"}]}], ")"}]}]}]}]}], 
   "]"}]}]}], "Input",

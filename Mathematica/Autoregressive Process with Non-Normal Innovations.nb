Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"n", "=", "300000"}], ",", 
     RowBox[{"equilibrium", "=", "24.5"}], ",", 
     RowBox[{"beta", "=", "0.03"}], ",", 
     RowBox[{"a", "=", 
      RowBox[{"-", "1.05"}]}], ",", 
     RowBox[{"b", "=", "0.0001"}], ",", 
     RowBox[{"c", "=", "2.2"}], ",", 
     RowBox[{"d", "=", "0.3"}]}], "}"}], ",", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"oldValue", "=", "equilibrium"}], ",", 
       RowBox[{"innovations", "=", 
        RowBox[{"jonesInverseCumulativeDistribution", "[", 
         RowBox[{
          RowBox[{"RandomReal", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"0", ",", "1"}], "}"}], ",", "n"}], "]"}], ",", "a", ",",
           "b", ",", "c", ",", "d"}], "]"}]}]}], "}"}], ",", 
     RowBox[{"With", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"data", "=", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"With", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"newValue", "=", 
               RowBox[{"oldValue", "+", 
                RowBox[{"beta", "*", 
                 RowBox[{"(", 
                  RowBox[{"equilibrium", "-", "oldValue"}], ")"}]}], "+", 
                "innovation"}]}], "}"}], ",", 
             RowBox[{"oldValue", "=", "newValue"}]}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"innovation", ",", "innovations"}], "}"}]}], "]"}]}], 
        "}"}], ",", 
       RowBox[{"Grid", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           
           RowBox[{"\"\<\>\"", ",", "\"\<Mean\>\"", ",", "\"\<Variance\>\"", 
            ",", "\"\<Skewness\>\"", ",", "\"\<Kurtosis\>\""}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"\"\<Innovation Moments from Data\>\"", ",", 
            RowBox[{"Mean", "[", "innovations", "]"}], ",", 
            RowBox[{"Variance", "[", "innovations", "]"}], ",", 
            RowBox[{"Skewness", "[", "innovations", "]"}], ",", 
            RowBox[{"Kurtosis", "[", "innovations", "]"}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"\"\<Innovation Prediction from Parameters\>\"", ",", 
            RowBox[{"jonesRawMoments", "[", 
             RowBox[{"1", ",", "a", ",", "b", ",", "c", ",", "d"}], "]"}], ",", 
            RowBox[{"jonesCentralMoments", "[", 
             RowBox[{"2", ",", "a", ",", "b", ",", "c", ",", "d"}], "]"}], ",", 
            RowBox[{"jonesStandardisedMoments", "[", 
             RowBox[{"3", ",", "a", ",", "b", ",", "c", ",", "d"}], "]"}], ",", 
            RowBox[{"jonesStandardisedMoments", "[", 
             RowBox[{"4", ",", "a", ",", "b", ",", "c", ",", "d"}], "]"}]}], 

Cell[BoxData[
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"PDF", "[", 
      RowBox[{
       RowBox[{"NormalDistribution", "[", "]"}], ",", "x"}], "]"}], ",", 
     RowBox[{"PDF", "[", 
      RowBox[{
       RowBox[{"NormalDistribution", "[", 
        RowBox[{"0.3", ",", "1"}], "]"}], ",", "x"}], "]"}], ",", 
     RowBox[{
      RowBox[{"PDF", "[", 
       RowBox[{
        RowBox[{"NormalDistribution", "[", "]"}], ",", "x"}], "]"}], 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", "+", 
          RowBox[{"Erf", "[", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"x", "-", "0.3"}], ")"}], "/", 
            RowBox[{"Sqrt", "[", "2", "]"}]}], "]"}]}], ")"}], "/", 
        RowBox[{"(", 
         RowBox[{"1", "+", 
          RowBox[{"Erf", "[", 
           RowBox[{"x", "/", 
            RowBox[{"Sqrt", "[", "2", "]"}]}], "]"}]}], ")"}]}], "/", 
       "s"}]}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", 
     RowBox[{"-", "4"}], ",", "4"}], "}"}]}], "]"}]], "Input",

 RowBox[{"0.9559974818331`", " ", 
  SuperscriptBox["\[ExponentialE]", 
   RowBox[{"0.3`", " ", "x"}]]}]], "Output",
 CellChangeTimes->{3.948782398166231*^9},
 CellLabel->"Out[18]=",ExpressionUUID->"f57603f9-1d2a-ca4e-8454-a25885474084"]

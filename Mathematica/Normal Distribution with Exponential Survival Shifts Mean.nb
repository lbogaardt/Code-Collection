Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Simplify", "[", 
  RowBox[{
   RowBox[{"PDF", "[", 
    RowBox[{
     RowBox[{"NormalDistribution", "[", 
      RowBox[{"m", ",", "1"}], "]"}], ",", "x"}], "]"}], "/", 
   RowBox[{"PDF", "[", 
    RowBox[{
     RowBox[{"NormalDistribution", "[", "]"}], ",", "x"}], "]"}]}], 
  "]"}]], "Input",
 CellChangeTimes->{{3.8438001676504955`*^9, 3.843800200263937*^9}},
 CellLabel->"In[19]:=",ExpressionUUID->"0f249e08-5737-4cb4-957b-56cf4d049112"],

Cell[BoxData[
 SuperscriptBox["\[ExponentialE]", 
  RowBox[{
   RowBox[{"-", 
    FractionBox[
     SuperscriptBox["m", "2"], "2"]}], "+", 
   RowBox[{"m", " ", "x"}]}]]], "Output",
 CellChangeTimes->{3.948782398199394*^9},
 CellLabel->"Out[19]=",ExpressionUUID->"0d6ef75b-878c-a140-b882-dd8a0222e4ae"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"biasedMean", "=", 
  RowBox[{"Integrate", "[", 
   RowBox[{
    RowBox[{"x", " ", 
     RowBox[{"PDF", "[", 
      RowBox[{
       RowBox[{"NormalDistribution", "[", 
        RowBox[{"mean", ",", "sd"}], "]"}], ",", "x"}], "]"}], 
     RowBox[{"Exp", "[", 
      RowBox[{
       RowBox[{"-", "h"}], " ", "x"}], "]"}]}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", 
      RowBox[{"-", "Infinity"}], ",", "Infinity"}], "}"}], ",", 
    RowBox[{"Assumptions", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{"sd", ">", "0"}], "}"}]}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.8447910592628655`*^9, 3.8447910763940797`*^9}, {
   3.8447911882912593`*^9, 3.8447911958754086`*^9}, {3.844791285023677*^9, 
   3.844791285228253*^9}, {3.8447913513474655`*^9, 3.844791380377614*^9}, 
   3.844791425487746*^9, {3.8447915168677425`*^9, 3.8447915169998884`*^9}, 
   3.8447916640397663`*^9, 3.844791718559435*^9, 3.8447917562457757`*^9},
 CellLabel->"In[20]:=",ExpressionUUID->"926a0068-20af-41e6-84e4-a337d4d59dcd"],

Cell[BoxData[
 RowBox[{
  SuperscriptBox["\[ExponentialE]", 
   RowBox[{
    FractionBox["1", "2"], " ", "h", " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"-", "2"}], " ", "mean"}], "+", 
      RowBox[{"h", " ", 
       SuperscriptBox["sd", "2"]}]}], ")"}]}]], " ", 
  RowBox[{"(", 
   RowBox[{"mean", "-", 
    RowBox[{"h", " ", 
     SuperscriptBox["sd", "2"]}]}], ")"}]}]], "Output",
 CellChangeTimes->{3.948782402799423*^9},
 CellLabel->"Out[20]=",ExpressionUUID->"484803c1-f361-cc4c-a9fb-ee98e64e4a23"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"biasedSD", "=", 
  RowBox[{"Integrate", "[", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"x", "-", "biasedMean"}], ")"}], "^", "2"}], " ", 
     RowBox[{"PDF", "[", 
      RowBox[{
       RowBox[{"NormalDistribution", "[", 
        RowBox[{"mean", ",", "sd"}], "]"}], ",", "x"}], "]"}], 
     RowBox[{"Exp", "[", 
      RowBox[{
       RowBox[{"-", "h"}], " ", "x"}], "]"}]}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", 
      RowBox[{"-", "Infinity"}], ",", "Infinity"}], "}"}], ",", 
    RowBox[{"Assumptions", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{"sd", ">", "0"}], "}"}]}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.8447913909642353`*^9, 3.8447914293227654`*^9}, {
   3.844791520040391*^9, 3.8447915201846743`*^9}, 3.844791678664287*^9},
 CellLabel->"In[21]:=",ExpressionUUID->"5e238765-00de-43be-b9a8-d1392637df8c"],

Cell[BoxData[
 RowBox[{
  SuperscriptBox["\[ExponentialE]", 
   RowBox[{
    FractionBox["1", "2"], " ", "h", " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"-", "6"}], " ", "mean"}], "+", 
      RowBox[{"h", " ", 
       SuperscriptBox["sd", "2"]}]}], ")"}]}]], " ", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{
       SuperscriptBox["h", "2"], " ", 
       SuperscriptBox["sd", "2"]}]], " ", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"mean", "-", 
        RowBox[{"h", " ", 
         SuperscriptBox["sd", "2"]}]}], ")"}], "2"]}], "-", 
    RowBox[{"2", " ", 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{
       RowBox[{"h", " ", "mean"}], "+", 
       FractionBox[
        RowBox[{
         SuperscriptBox["h", "2"], " ", 
         SuperscriptBox["sd", "2"]}], "2"]}]], " ", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"mean", "-", 
        RowBox[{"h", " ", 
         SuperscriptBox["sd", "2"]}]}], ")"}], "2"]}], "+", 
    RowBox[{
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"2", " ", "h", " ", "mean"}]], " ", 
     RowBox[{"(", 
      RowBox[{
       SuperscriptBox["sd", "2"], "+", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"mean", "-", 
          RowBox[{"h", " ", 
           SuperscriptBox["sd", "2"]}]}], ")"}], "2"]}], ")"}]}]}], 
   ")"}]}]], "Output",
 CellChangeTimes->{3.948782417100361*^9},
 CellLabel->"Out[21]=",ExpressionUUID->"fc4b444d-2dfe-7248-8c7b-89a9f7159d66"]

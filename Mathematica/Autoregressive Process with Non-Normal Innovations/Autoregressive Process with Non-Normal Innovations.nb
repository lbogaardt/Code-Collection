Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"n", "=", "300000"}], ",", 
     RowBox[{"equilibrium", "=", "24.5"}], ",", 
     RowBox[{"beta", "=", "0.03"}], ",", 
     RowBox[{"a", "=", 
      RowBox[{"-", "1.05"}]}], ",", 
     RowBox[{"b", "=", "0.0001"}], ",", 
     RowBox[{"c", "=", "2.2"}], ",", 
     RowBox[{"d", "=", "0.3"}]}], "}"}], ",", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"oldValue", "=", "equilibrium"}], ",", 
       RowBox[{"innovations", "=", 
        RowBox[{"jonesInverseCumulativeDistribution", "[", 
         RowBox[{
          RowBox[{"RandomReal", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"0", ",", "1"}], "}"}], ",", "n"}], "]"}], ",", "a", ",",
           "b", ",", "c", ",", "d"}], "]"}]}]}], "}"}], ",", 
     RowBox[{"With", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"data", "=", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"With", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"newValue", "=", 
               RowBox[{"oldValue", "+", 
                RowBox[{"beta", "*", 
                 RowBox[{"(", 
                  RowBox[{"equilibrium", "-", "oldValue"}], ")"}]}], "+", 
                "innovation"}]}], "}"}], ",", 
             RowBox[{"oldValue", "=", "newValue"}]}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"innovation", ",", "innovations"}], "}"}]}], "]"}]}], 
        "}"}], ",", 
       RowBox[{"Grid", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
           "\"\<\>\"", ",", "\"\<Mean\>\"", ",", "\"\<Variance\>\"", ",", 
            "\"\<Skewness\>\"", ",", "\"\<Kurtosis\>\""}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"\"\<Innovation Moments from Data\>\"", ",", 
            RowBox[{"Mean", "[", "innovations", "]"}], ",", 
            RowBox[{"Variance", "[", "innovations", "]"}], ",", 
            RowBox[{"Skewness", "[", "innovations", "]"}], ",", 
            RowBox[{"Kurtosis", "[", "innovations", "]"}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"\"\<Innovation Prediction from Parameters\>\"", ",", 
            RowBox[{"jonesRawMoments", "[", 
             RowBox[{"1", ",", "a", ",", "b", ",", "c", ",", "d"}], "]"}], 
            ",", 
            RowBox[{"jonesCentralMoments", "[", 
             RowBox[{"2", ",", "a", ",", "b", ",", "c", ",", "d"}], "]"}], 
            ",", 
            RowBox[{"jonesStandardisedMoments", "[", 
             RowBox[{"3", ",", "a", ",", "b", ",", "c", ",", "d"}], "]"}], 
            ",", 
            RowBox[{"jonesStandardisedMoments", "[", 
             RowBox[{"4", ",", "a", ",", "b", ",", "c", ",", "d"}], "]"}]}], 
           "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"\"\<Innovation Prediction from Process\>\"", ",", 
            RowBox[{"innovationsMeanFromProcess", "[", 
             RowBox[{"equilibrium", ",", 
              RowBox[{"Mean", "[", "data", "]"}], ",", "beta"}], "]"}], ",", 
            RowBox[{"innovationsVarianceFromProcess", "[", 
             RowBox[{
              RowBox[{"Variance", "[", "data", "]"}], ",", "beta"}], "]"}], 
            ",", 
            RowBox[{"innovationsSkewnessFromProcess", "[", 
             RowBox[{
              RowBox[{"Skewness", "[", "data", "]"}], ",", "beta"}], "]"}], 
            ",", 
            RowBox[{"innovationsKurtosisFromProcess", "[", 
             RowBox[{
              RowBox[{"Kurtosis", "[", "data", "]"}], ",", "beta"}], "]"}]}], 
           "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"\"\<Process Moments from Data\>\"", ",", 
            RowBox[{"Mean", "[", "data", "]"}], ",", 
            RowBox[{"Variance", "[", "data", "]"}], ",", 
            RowBox[{"Skewness", "[", "data", "]"}], ",", 
            RowBox[{"Kurtosis", "[", "data", "]"}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"\"\<Process Prediction from Parameters\>\"", ",", 
            RowBox[{"processMeanFromInnovations", "[", 
             RowBox[{"equilibrium", ",", 
              RowBox[{"jonesRawMoments", "[", 
               RowBox[{"1", ",", "a", ",", "b", ",", "c", ",", "d"}], "]"}], 
              ",", "beta"}], "]"}], ",", 
            RowBox[{"processVarianceFromInnovations", "[", 
             RowBox[{
              RowBox[{"jonesCentralMoments", "[", 
               RowBox[{"2", ",", "a", ",", "b", ",", "c", ",", "d"}], "]"}], 
              ",", "beta"}], "]"}], ",", 
            RowBox[{"processSkewnessFromInnovations", "[", 
             RowBox[{
              RowBox[{"jonesStandardisedMoments", "[", 
               RowBox[{"3", ",", "a", ",", "b", ",", "c", ",", "d"}], "]"}], 
              ",", "beta"}], "]"}], ",", 
            RowBox[{"processKurtosisFromInnovations", "[", 
             RowBox[{
              RowBox[{"jonesStandardisedMoments", "[", 
               RowBox[{"4", ",", "a", ",", "b", ",", "c", ",", "d"}], "]"}], 
              ",", "beta"}], "]"}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"\"\<Process Prediction from Innovations\>\"", ",", 
            RowBox[{"processMeanFromInnovations", "[", 
             RowBox[{"equilibrium", ",", 
              RowBox[{"Mean", "[", "innovations", "]"}], ",", "beta"}], "]"}],
             ",", 
            RowBox[{"processVarianceFromInnovations", "[", 
             RowBox[{
              RowBox[{"Variance", "[", "innovations", "]"}], ",", "beta"}], 
             "]"}], ",", 
            RowBox[{"processSkewnessFromInnovations", "[", 
             RowBox[{
              RowBox[{"Skewness", "[", "innovations", "]"}], ",", "beta"}], 
             "]"}], ",", 
            RowBox[{"processKurtosisFromInnovations", "[", 
             RowBox[{
              RowBox[{"Kurtosis", "[", "innovations", "]"}], ",", "beta"}], 
             "]"}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"\"\<Distribution Plots\>\"", ",", 
            RowBox[{"Histogram", "[", "innovations", "]"}], ",", 
            RowBox[{"SmoothHistogram", "[", "innovations", "]"}], ",", 
            RowBox[{"Histogram", "[", "data", "]"}], ",", 
            RowBox[{"SmoothHistogram", "[", "data", "]"}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"\"\<Distribution over time\>\"", ",", 
            RowBox[{"Histogram", "[", 
             RowBox[{"Take", "[", 
              RowBox[{"data", ",", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{
                  RowBox[{"1", "/", "5"}], "n"}], ",", 
                 RowBox[{
                  RowBox[{"2", "/", "5"}], "n"}]}], "}"}]}], "]"}], "]"}], 
            ",", 
            RowBox[{"SmoothHistogram", "[", 
             RowBox[{"Take", "[", 
              RowBox[{"data", ",", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{
                  RowBox[{"1", "/", "5"}], "n"}], ",", 
                 RowBox[{
                  RowBox[{"2", "/", "5"}], "n"}]}], "}"}]}], "]"}], "]"}], 
            ",", 
            RowBox[{"Histogram", "[", 
             RowBox[{"Take", "[", 
              RowBox[{"data", ",", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{
                  RowBox[{"3", "/", "5"}], "n"}], ",", 
                 RowBox[{
                  RowBox[{"4", "/", "5"}], "n"}]}], "}"}]}], "]"}], "]"}], 
            ",", 
            RowBox[{"SmoothHistogram", "[", 
             RowBox[{"Take", "[", 
              RowBox[{"data", ",", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{
                  RowBox[{"3", "/", "5"}], "n"}], ",", 
                 RowBox[{
                  RowBox[{"4", "/", "5"}], "n"}]}], "}"}]}], "]"}], "]"}]}], 
           "}"}], ",", 
          RowBox[{"Join", "[", 
           RowBox[{
            RowBox[{"{", "\"\<Process Plots\>\"", "}"}], ",", 
            RowBox[{"Table", "[", 
             RowBox[{
              RowBox[{"ListPlot", "[", 
               RowBox[{"Take", "[", 
                RowBox[{"data", ",", 
                 RowBox[{"{", 
                  RowBox[{
                   RowBox[{"1000", "p"}], ",", 
                   RowBox[{
                    RowBox[{"1000", "p"}], "+", "100"}]}], "}"}]}], "]"}], 
               "]"}], ",", 
              RowBox[{"{", 
               RowBox[{"p", ",", "1", ",", "4"}], "}"}]}], "]"}]}], "]"}], 
          ",", 
          RowBox[{"Join", "[", 
           RowBox[{
            RowBox[{"{", "\"\<Process Plots\>\"", "}"}], ",", 
            RowBox[{"Table", "[", 
             RowBox[{
              RowBox[{"ListPlot", "[", 
               RowBox[{"Take", "[", 
                RowBox[{"data", ",", 
                 RowBox[{"{", 
                  RowBox[{
                   RowBox[{"1000", "p"}], ",", 
                   RowBox[{
                    RowBox[{"1000", "p"}], "+", "100"}]}], "}"}]}], "]"}], 
               "]"}], ",", 
              RowBox[{"{", 
               RowBox[{"p", ",", "5", ",", "8"}], "}"}]}], "]"}]}], "]"}]}], 
         "}"}], "]"}]}], "]"}]}], "]"}]}], "]"}]], "Input",

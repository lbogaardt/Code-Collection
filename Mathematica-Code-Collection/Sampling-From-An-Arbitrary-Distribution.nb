             RowBox[{"{", 
              RowBox[{"Graphics", "[", 
               RowBox[{"Inset", "[", 
                RowBox[{
                 RowBox[{"Histogram", "[", 
                  RowBox[{
                  "data", ",", "Automatic", ",", "\"\<Probability\>\"", ",", 
                   RowBox[{"PlotRange", "\[Rule]", 
                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{"{", 
                    RowBox[{"0", ",", "1"}], "}"}], ",", "Automatic"}], 
                    "}"}]}]}], "]"}], ",", "Center", ",", "Center", ",", 
                 "1.8", ",", 
                 RowBox[{
                  RowBox[{"RotationTransform", "[", 
                   RowBox[{"90", "*", "Degree"}], "]"}], "[", 
                  RowBox[{"{", 
                   RowBox[{"1", ",", "0"}], "}"}], "]"}]}], "]"}], "]"}], 
              "}"}], ",", 
             RowBox[{"ImageSize", "\[Rule]", "400"}]}], "]"}], ",", 
           RowBox[{"Show", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{
               RowBox[{"Plot", "[", 
                RowBox[{
                 RowBox[{"CDF", "[", 
                  RowBox[{
                   RowBox[{"NormalDistribution", "[", "]"}], ",", "x"}], 
                  "]"}], ",", 
                 RowBox[{"{", 
                  RowBox[{"x", ",", 
                   RowBox[{"-", "4"}], ",", "4"}], "}"}], ",", 
                 RowBox[{"PlotRange", "\[Rule]", 
                  RowBox[{"{", 
                   RowBox[{
                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{"-", "4"}], ",", "4"}], "}"}], ",", 
                    RowBox[{"{", 
                    RowBox[{"0", ",", "1"}], "}"}]}], "}"}]}]}], "]"}], ",", 
               RowBox[{"Graphics", "[", 
                RowBox[{"{", 
                 RowBox[{"Red", ",", 
                  RowBox[{"Arrow", "[", 
                   RowBox[{"{", 
                    RowBox[{
                    RowBox[{"{", 
                    RowBox[{"0", ",", "value"}], "}"}], ",", 
                    RowBox[{"{", 
                    RowBox[{"inverse", ",", "value"}], "}"}]}], "}"}], "]"}], 
                  ",", 
                  RowBox[{"Arrow", "[", 
                   RowBox[{"{", 
                    RowBox[{
                    RowBox[{"{", 
                    RowBox[{"inverse", ",", "value"}], "}"}], ",", 
                    RowBox[{"{", 
                    RowBox[{"inverse", ",", "0"}], "}"}]}], "}"}], "]"}]}], 
                 "}"}], "]"}]}], "}"}], ",", 
             RowBox[{"ImageSize", "\[Rule]", "500"}]}], "]"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"Null", ",", 
           RowBox[{"Show", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"Histogram", "[", 
               RowBox[{
               "datainverse", ",", "Automatic", ",", "\"\<Probability\>\"", ",", 
                RowBox[{"PlotRange", "\[Rule]", 
                 RowBox[{"{", 
                  RowBox[{
                   RowBox[{"{", 
                    RowBox[{

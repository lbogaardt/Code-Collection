Cell[BoxData[
 RowBox[{
  RowBox[{"bernsteinCoefficients", "[", "pol_", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"t", ",", "n", ",", "c", ",", "a"}], "}"}], ",", 
    RowBox[{
     RowBox[{"t", "=", 
      RowBox[{
       RowBox[{"Variables", "[", "pol", "]"}], "[", 
       RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"n", "=", 
      RowBox[{"Exponent", "[", 
       RowBox[{"pol", ",", "t"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"c", "=", 
      RowBox[{
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"a", "[", "k", "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"k", ",", "0", ",", "n"}], "}"}]}], "]"}], "/.", 
       RowBox[{
        RowBox[{"SolveAlways", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Sum", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"a", "[", "k", "]"}], " ", 
              RowBox[{"Binomial", "[", 
               RowBox[{"n", ",", "k"}], "]"}], " ", 
              RowBox[{"t", "^", 
               RowBox[{"(", 
                RowBox[{"n", "-", "k"}], ")"}]}], " ", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{"1", "-", "t"}], ")"}], "^", "k"}]}], ",", 
             RowBox[{"{", 
              RowBox[{"k", ",", "0", ",", "n"}], "}"}]}], "]"}], "\[Equal]", 
           "pol"}], ",", "t"}], "]"}], "[", 
        RowBox[{"[", "1", "]"}], "]"}]}]}], ";", 
     RowBox[{"c", "/", 
      RowBox[{"Total", "[", "c", "]"}]}]}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.8623820574059143`*^9, 3.862382058458096*^9}, {
  3.8623859911147785`*^9, 3.8623860054958916`*^9}, {3.8624073715972424`*^9, 
  3.8624073770726633`*^9}},
 CellLabel->"In[5]:=",ExpressionUUID->"0700d8ce-d120-4132-aa9e-f48088d6ab09"],

Cell[BoxData[
 RowBox[{"DynamicModule", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"polynomial", "=", "0"}], ",", 
     RowBox[{"distribution", "=", 
      RowBox[{"NormalDistribution", "[", "]"}]}], ",", 
     RowBox[{"coefficients", "=", 
      RowBox[{"{", "}"}]}], ",", 
     RowBox[{"data", "=", 
      RowBox[{"{", "}"}]}], ",", 
     RowBox[{"parameters", "=", 
      RowBox[{"{", "}"}]}]}], "}"}], ",", 
   RowBox[{"Manipulate", "[", 
    RowBox[{
     RowBox[{"Grid", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"Show", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"Plot", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"Function", "[", 
                 RowBox[{
                  RowBox[{"{", "x", "}"}], ",", 
                  RowBox[{"InterpolatingPolynomial", "[", 
                   RowBox[{
                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{"{", 
                    RowBox[{"0", ",", "0.7"}], "}"}], ",", "p1", ",", "p2", ",",
                     "p3", ",", 
                    RowBox[{"{", 
                    RowBox[{"1", ",", "0.1"}], "}"}]}], "}"}], ",", "x"}], 
                   "]"}]}], "]"}], "[", "x", "]"}], ",", 
               RowBox[{"{", 
                RowBox[{"x", ",", "0", ",", "1"}], "}"}], ",", 
               RowBox[{"PlotRange", "\[Rule]", 
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"{", 
                   RowBox[{"0", ",", "1"}], "}"}], ",", 
                  RowBox[{"{", 
                   RowBox[{"0", ",", "1"}], "}"}]}], "}"}]}]}], "]"}], "}"}], 
            ",", 
            RowBox[{"ImageSize", "\[Rule]", "500"}]}], "]"}], ",", 
          RowBox[{"Show", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"Histogram", "[", 
              RowBox[{"data", ",", "Automatic", ",", "\"\<Probability\>\""}], 
              "]"}], "}"}], ",", 
            RowBox[{"ImageSize", "\[Rule]", "500"}]}], "]"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"coefficients", ",", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"w1", ",", "w2", ",", "w3", ",", "w4", ",", 
             RowBox[{"1", "-", "w1", "-", "w2", "-", "w3", "-", "w4"}]}], 
            "}"}], "/.", "parameters"}]}], "}"}]}], "}"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"p1", ",", 
         RowBox[{"{", 
          RowBox[{".25", ",", "0.6"}], "}"}]}], "}"}], ",", "Locator"}], 
      "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"p2", ",", 
         RowBox[{"{", 
          RowBox[{"0.5", ",", "0.7"}], "}"}]}], "}"}], ",", "Locator"}], 
      "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"p3", ",", 
         RowBox[{"{", 
          RowBox[{".75", ",", "0.5"}], "}"}]}], "}"}], ",", "Locator"}], 
      "}"}], ",", 
     RowBox[{"Button", "[", 
      RowBox[{"\"\<Generate\>\"", ",", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"polynomial", "=", 
           RowBox[{"InterpolatingPolynomial", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{"0", ",", "0.7"}], "}"}], ",", "p1", ",", "p2", ",", 
               "p3", ",", 
               RowBox[{"{", 
                RowBox[{"1", ",", "0.1"}], "}"}]}], "}"}], ",", "x"}], 
            "]"}]}], ",", 
          RowBox[{"coefficients", "=", 
           RowBox[{"bernsteinCoefficients", "[", "polynomial", "]"}]}], ",", 
          RowBox[{"distribution", "=", 
           RowBox[{"MixtureDistribution", "[", 
            RowBox[{"coefficients", ",", 
             RowBox[{"Table", "[", 
              RowBox[{
               RowBox[{"BetaDistribution", "[", 
                RowBox[{
                 RowBox[{
                  RowBox[{"Length", "[", "coefficients", "]"}], "-", "i"}], ",", 
                 RowBox[{"i", "+", "1"}]}], "]"}], ",", 
               RowBox[{"{", 
                RowBox[{"i", ",", "0", ",", 
                 RowBox[{
                  RowBox[{"Length", "[", "coefficients", "]"}], "-", "1"}]}], 
                "}"}]}], "]"}]}], "]"}]}], ",", 
          RowBox[{"data", "=", 
           RowBox[{"RandomVariate", "[", 
            RowBox[{"distribution", ",", "20000"}], "]"}]}], ",", 
          RowBox[{"Quiet", "[", 
           RowBox[{"parameters", "=", 
            RowBox[{"FindDistributionParameters", "[", 
             RowBox[{"data", ",", 
              RowBox[{"MixtureDistribution", "[", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{"w1", ",", "w2", ",", "w3", ",", "w4", ",", 
                  RowBox[{"1", "-", "w1", "-", "w2", "-", "w3", "-", "w4"}]}],
                  "}"}], ",", 
                RowBox[{"Evaluate", "[", 
                 RowBox[{"Table", "[", 
                  RowBox[{
                   RowBox[{"BetaDistribution", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"Length", "[", "coefficients", "]"}], "-", "i"}], 
                    ",", 
                    RowBox[{"i", "+", "1"}]}], "]"}], ",", 
                   RowBox[{"{", 

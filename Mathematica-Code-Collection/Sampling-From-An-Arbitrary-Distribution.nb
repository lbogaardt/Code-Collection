Cell[BoxData[
 RowBox[{"DynamicModule", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"data", "=", 
      RowBox[{"List", "[", "]"}]}], ",", 
     RowBox[{"datainverse", "=", 
      RowBox[{"List", "[", "]"}]}], ",", 
     RowBox[{"value", "=", "0.5"}], ",", 
     RowBox[{"inverse", "=", 
      RowBox[{"InverseCDF", "[", 
       RowBox[{
        RowBox[{"NormalDistribution", "[", "]"}], ",", "0.5"}], "]"}]}]}], 
    "}"}], ",", 
   RowBox[{"Manipulate", "[", 
    RowBox[{
     RowBox[{"Grid", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Show", "[", 
